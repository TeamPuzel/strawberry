    },
    "identifier": {
      "type": "PATTERN",
      "value": "[a-z_][a-zA-Z0-9_]*"
    },
    "operator": {
      "type": "PATTERN",
      "value": "[+\\-*/%<>=!&|^~?]+"
    },
    "punctuation": {
      "type": "CHOICE",
      "members": [
