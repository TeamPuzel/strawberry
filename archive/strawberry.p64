-- Tokenizer --------------------------------------------------------------------------

-- Creates an iterator from a string which yields
-- tokens of the strawberry programming language.
-- This iterator is a callable table and has other
-- functionality, most notably the ability to peek.
-- It must be provided a source identifier
-- to tag tokens with their provenance, such as
-- a specific path to a source file or some other
-- construct in an environment without files.
--
-- The source provided can also be a span, in which case
-- the span will be used to override all positional information
-- for every token. This is used for synthesized code as it
-- does not exist in source code and must inherit location instead.
function tokenize(str, source)
	assert(str)
	source = source or {}
	
	local i = 1
	local c = #str
	
	local ln = 1
	local col = 1
	
	local consumed_count = 0
	
	local last_token
	
	local function consume(n)
		i += n or 1
		col += n or 1
		consumed_count += n or 1
	end
	
	local function rewind(n)
		i -= n or 1
		col -= n or 1
		consumed_count -= n or 1
	end
	
	local function take()
		return str[i]
	end
	
	local function is(c)
		return str[i] == c
	end
	
	local function are(s)
		for j = 1, #s do
			if s[j] ~= str[i + j - 1] then
				return false
			end
		end
		
		return true
	end
	
	local function is_in_range(from, to)
		return take() >= from and take() <= to
	end
	
	local function is_valid_ident()
		return
			not is_in_range(chr(0), chr(31)) and
			not is(chr(127)) and
			not is " " and
			not is "\"" and
			not is "#" and
			not is "'" and
			not is "(" and
			not is ")" and
			not is "," and
			not is ":" and
			not is ";" and
			not is "@" and
			not is "[" and
			not is "\\" and
			not is "]" and
			not is "{" and
			not is "}"
	end
	
	local function is_valid_digit()
		return
			is_in_range("0", "9") or
			is_in_range("A", "Z") or
			is_in_range("a", "z")
	end
	
	local function is_valid_symbol_ident()
		return
			is_valid_ident() and
			not is_in_range("0", "9") and
			not is_in_range("A", "Z") and
			not is_in_range("a", "z") and
			not is "_"
	end
	
	local function is_valid_pure_ident()
		return
			is_in_range("0", "9") or
			is_in_range("A", "Z") or
			is_in_range("a", "z") or
			is "_"
	end
	
	local function no_tok()
		consumed_count = 0
	end
	
	local function tok(tbl)
		tbl.sym = tbl[1]
		tbl[1] = nil
		
		if source.is_span then
			local origin = source.last
			tbl.source = origin.source
			tbl.start = origin.start
			tbl.count = origin.count
			tbl.line = origin.line
			tbl.column = origin.column
		else
			tbl.source = source
			tbl.start = i - 1
			tbl.count = consumed_count
			tbl.line = ln
			tbl.column = col - 1
		end
		
		consumed_count = 0
		
		last_token = tbl
		
		return setmetatable(tbl, {
			__tostring = tokstr
		})
	end
	
	local function over()
		return i > c
	end
	
	local function throw(reason, help_text)
		error {
			kind = "error",
			reason = reason,
			span = span(last_token),
			help_text = help_text
		}
	end
	
	local function raw_iter()
		::impl::
		if (over()) return nil
		
		if is " " then
			local n = 0
			while is " " and not over() do
				consume(1)
				n += 1
			end
			-- return tok { " ", n = n }
			no_tok()
			goto impl
		elseif 
			is "\n" or is "(" or is ")" or is "{" or is "}" or
			is "[" or is "]" or is "," or is ":" or is ";" or
			is "@" or is "#" or is "'" or (is "." and not are "..")
		then
			local isnewline = is "\n"
			
			local leading_ws =
				(str[i - 1] or " ") == " " or
				str[i - 1] == "\n"
			
			local ret = take()
			consume(1)
			
			local trailing_ws =
				(str[i] or " ") == " " or
				str[i] == "\n"
			
			local token = tok { ret, leading_ws = leading_ws, trailing_ws = trailing_ws }
			
			if isnewline then
				ln += 1
				col = 1
			end
			
			return token
		elseif are "->" then
			consume(2)
			return tok { "->" }
		elseif are "//" then
			consume(2)
			
			local sel = ""
				
			while not over() and not is " " and not is "\n" do
				sel ..= take()
				consume(1)
			end
			
			if is " " then
    			consume(1)
			end
			
			if (#sel == 0) sel = nil
			
			local buf = ""
			
			while not over() and not is "\n" do
				buf ..= take()
				consume(1)
			end
			consume(1)
			
			ln += 1
			col = 1
			
			if sel then
				return tok { "//", sel = sel, buf = buf }
			else
				no_tok()
				goto impl
			end
		elseif are "\\\\ " then
			consume(3)
			
			local buf = ""
			
			while not over() and not is "\n" do
				buf ..= take()
				consume(1)
			end
			
			ln += 1
			col = 1
			
			return tok { "\\", buf = buf }
		elseif is "\"" then
			consume(1)
			
			local buf = ""
			
			while not is "\"" do
				buf ..= take()
				consume(1)
			end
			
			consume(1)
			
			return tok { "str", buf = buf }
		elseif is_in_range("0", "9") then
			local n = 0
			local start = i
			
			::num_loop::
			consume(1)
			n += 1
			
			if over() then
			elseif is_valid_digit() then
				goto num_loop
			elseif is "_" then
				consume(1)
				if not is_valid_digit() then
					throw "invalid underscore"
				end
				rewind(1)
				
				goto num_loop
			elseif is "." and not are ".." then
				consume(1)
				if not is_valid_digit() then
					throw "invalid separator"
				end
				rewind()
				
				goto num_loop
			end
			
			return tok { "number", buf = sub(str, start, start + n - 1) }
		elseif is_valid_symbol_ident() then
			local buf = ""
			
			local leading_ws =
				(str[i - 1] or " ") == " " or
				str[i - 1] == "\n"
			
			repeat
				buf ..= take()
				consume(1)
			until over() or not is_valid_symbol_ident()
			
			local trailing_ws =
				(str[i] or " ") == " " or
				str[i] == "\n" or
				str[i] == "," or
				str[i] == ">" or
				str[i] == ")"
			
			return tok {
				"ident",
				buf = buf,
				leading_ws = leading_ws,
				trailing_ws = trailing_ws,
				symbolic = true
			}
		elseif is_valid_pure_ident() then
			local buf = ""
			
			repeat
				buf ..= take()
				consume(1)
			until over() or not is_valid_pure_ident()
			
			if buf == "_" then
				return tok { "_" }
			else
				return tok { "ident", buf = buf, symbolic = false }
			end
		else
			throw "invalid token"
		end
	end
	
	local iter = setmetatable({}, {
		__call = raw_iter
	})
	
	iter.source = source
	
	local last_consumed_token
	
	function iter:peek(n)
		n = n or 1
		
		local pi = i
		local pln = ln
		local pcol = col
		local pconsumed_count = consumed_count
		
		local token
		for _ = 1, n do
			token = self()
		end
		
		i = pi
		ln = pln
		col = pcol
		consumed_count = pconsumed_count
		
		return token
	end
	
	function iter:consume(n)
		for _ = 1, n or 1 do
			last_consumed_token = self()
		end
	end
	
	function iter:consume_while(pred)
		local token = self:peek()
		while token and pred(token) do
			last_consumed_token = self()
			token = self:peek()
		end
	end
	
	function iter:match(sym, cmp)
		local token = self:peek()
		
		if token and token.sym == sym then
			if cmp then
				for k, v in pairs(cmp) do
					if (token[k] ~= v) return nil
				end
			end
			
			last_consumed_token = self()
			return last_consumed_token
		end
	end
	
	-- Like match but does not contribute to the last consumed token,
	-- so for example allowing a trailing newline after a declaration
	-- will not include it as part of a span used directly afterwards.
	function iter:allow(sym, cmp)
		local token = self:peek()
		
		if token and token.sym == sym then
			if cmp then
				for k, v in pairs(cmp) do
					if (token[k] ~= v) return nil
				end
			end
			
			return self()
		end
	end
	
	function iter:is_match(sym, cmp)
		return self:match(sym, cmp) ~= nil
	end
	
	function iter:expect(sym, cmp)
		local token = self:match(sym, cmp)
		if not token then
			self:throw("unexpected token: " .. tokstr(self:peek()))
		end
		return token
	end
	
	function iter:assert(sym, cmp)
		if not self:is(sym, cmp) then
			self:throw("unexpected token: " .. tokstr(self:peek()))
		end
	end
	
	function iter:is(sym, cmp)
		local token = self:peek()
		
		if token and token.sym == sym then
			if cmp then
				for k, v in pairs(cmp) do
					if (token[k] ~= v) return false
				end
			end
			
			return true
		else
			return false
		end
	end
	
	function iter:are(...)
		local pi = i
		
		for n = 1, select("#", ...) do
			if self().sym ~= select(n, ...) then
				return false
			end
		end
		
		i = pi
		
		return true
	end
	
	function iter:is_done()
		return self:peek() == nil
	end
	
	function iter:throw(reason, help_text)
		local token = self:peek() or last_consumed_token -- in case the file ended
		error {
			kind = "error",
			reason = reason,
			span = span(token, token),
			help_text = help_text
		}
	end
	
	function iter:drain(sym, cmp)
		local result = false
		if (self:is(sym, cmp)) result = true
		while self:allow(sym, cmp) do end
		return result
	end
	
	local span_stack = {}
	
	function iter:span()
		add(span_stack, self:peek())
	end
	
	function iter:endspan()
		local first = deli(span_stack)
		local last = last_consumed_token
		return span(first, last)
	end
	
	return iter
end

function span(first, last)
	return {
		is_span = true,
		first = first,
		last = last or first
	}
end

function nilspan(source)
	local dummy = { source = source, line = 1, column = 1, count = 1, start = 1 }
	local result = span(dummy)
	result.is_dummy = true
	return result
end

function tokstr(token)
	if token.sym == "ident" then
		if token.symbolic then
			return
				"ident.sym: '" .. token.buf .. "' " ..
				"leading: " .. tostr(token.leading_ws) ..
				" trailing: " .. tostr(token.trailing_ws)
		else
			return
				"ident: '" .. token.buf .. "'"
		end
	elseif token.sym == "str" then
		return "str: '" .. token.buf .. "'"
	elseif token.sym == "number" then
		return "num: " .. tostr(token.buf)
	elseif token.sym == "error" then
		return "error: " .. token.msg
	elseif token.sym == "\n" then
		return "'\\n'"
	else
		return "'" .. token.sym .. "'"
	end
end

-- Parser -----------------------------------------------------------------------------

path = {}

function path.name(p)
	local idx
	
	for i = #p, 1, -1 do
		if p[i] == "." then
			idx = i
			break
		end
	end
	
	if (not idx) return p
	
	return sub(p, idx + 1, -1)
end

function path.prefix(p)
	local idx
	
	for i = #p, 1, -1 do
		if p[i] == "." then
			idx = i 
			break
		end
	end
	
	if (not idx) return nil
	
	return sub(p, 1, idx - 1)
end

function path.concat(...)
	return table.concat(pack(...), ".")
end

function path.split(p)
	return split(p, ".")
end

function path.join(p)
	return table.concat(p, ".")
end

-- Traverses the path checking if it's nested in another.
function path.nested_in(p, other)
	if (p == nil) return false
	if (p == other) return true
	path.nested_in(path.prefix(p), other)
end

-- The parser entry point, receives a token iterator
-- for a module and parses it into a syntax tree.
function parse(tok)
	if tok:is("ident", { buf = "ignored" }) then
		return nil
	end
	
	local ast = {
		name = parse_module_header(tok),
		decls = {},
		source = tok.source
	}
	
	while not tok:is_done() do
		tok:consume_while(function(token)
			return token.sym == "\n"
		end)
		add(ast.decls, parse_decl(tok))
	end
	
	return ast
end

-- A simple parser for the module header.
function parse_module_header(tok)
	tok:expect("ident", { buf = "module" })
	
	local pathbuf = {}
	
	repeat
		add(pathbuf, tok:expect("ident").buf)
	until not tok:match(".")
	
	tok:match("\n")
	
	return path.join(pathbuf)
end

function declnode(v)
	return setmetatable(v, {
		__tostring = declstr
	})
end

function declstr(node)
	if node.kind == "fun" then
		local buf = ""
		if (node.pub) buf ..= "pub "
		if (node.override) buf ..= "override "
		if (node.open) buf ..= "open "
		if (node.unsafe) buf ..= "unsafe "
		if (node.const) buf ..= "const "
		
		if node.operator_kind then
			buf ..= (node.operator_kind .. " operator " .. node.operator .. " ")
		end
		
		buf ..= "fun "
		buf ..= node.name
		
		if node.generics then
			
		end
		
		local args = {}
		for arg in all(node.args) do
			
		end
		
		buf ..= ("(" .. table.concat(args, ", ") .. ")")
		
		if node.throws then
		
		end
		
		if node.returns then
			buf ..= (" -> " .. tostring(node.returns))
		end
		
		buf ..= (" " .. tostring(node.body))
		
		return buf
	else
		return "<?decl:" .. node.kind .. ">"
	end
end

function parse_decl(tok)
	local doc = {}
	
	while tok:is("//", { sel = "/" }) do
		add(doc, tok().buf)
	end
	
	doc = table.concat(doc, "\n")
	
	local annotations = {}
	
	while tok:is_match("@") do
		add(annotations, parse_expr(tok))
		tok:match("\n")
	end
	
	local pub = tok:is_match("ident", { buf = "pub" })
	local unsafe = tok:is_match("ident", { buf = "unsafe" })
	local open = tok:is_match("ident", { buf = "open" })
	local override = tok:is_match("ident", { buf = "override" })
	local inherent = tok:is_match("ident", { buf = "inherent" })
	local const = tok:is_match("ident", { buf = "const" })
	local static = tok:is_match("ident", { buf = "static" })
	local inline = tok:is_match("ident", { buf = "inline" })
	local implicit = tok:is_match("ident", { buf = "implicit" })
	local base = tok:is_match("ident", { buf = "base" })
	
	local token = tok:peek()
	tok:assert("ident")
	local ident = token.buf
	
	local decl
	if
		ident == "fun" or 
		ident == "infix" or
		ident == "prefix" or 
		ident == "postfix"
	then
		decl = parse_fun(tok)
	elseif ident == "init" then
		decl = parse_init(tok)
	elseif ident == "struct" then
		decl = parse_struct(tok)
	elseif ident == "enum" then
		decl = parse_enum(tok)
	elseif ident == "category" then
		decl = parse_category(tok)
	elseif ident == "extend" then
		decl = parse_ext(tok)
	elseif ident == "type" then
		decl = parse_type(tok)
	elseif ident == "class" then
		decl = parse_class(tok)
	elseif ident == "let" then
		decl = parse_member(tok)
	elseif ident == "object" then
		decl = parse_object(tok)
	elseif ident == "annotation" then
		decl = parse_annotation(tok)
	elseif ident == "import" then
		decl = parse_import(tok)
	else
		tok:throw "invalid declaration"
	end
	
	decl.doc = doc
	decl.annotations = annotations
	decl.pub = pub
	decl.override = override
	decl.unsafe = unsafe
	decl.inherent = inherent
	decl.const = const
	decl.static = static
	decl.open = open
	decl.implicit = implicit
	decl.base = base
	decl.inline = inline
	
	return decl
end

function parse_import(tok)
	tok:span()
	tok:expect("ident", { buf = "import" })
	
	local pathbuf = {}
	local alias
	
	repeat
		add(pathbuf, tok:expect("ident").buf)
	until not tok:match(".")
	
	if tok:match("ident", { buf = "as" }) then
		alias = tok:expect("ident", { symbolic = false }).buf
	end
	
	if (not tok:is_done()) tok:expect("\n")

	return declnode {
		kind = "import",
		path = path.join(pathbuf),
		span = tok:endspan(),
		alias = alias
	}
end

function parse_fun(tok)
	tok:span()
	local operator_kind, operator, operator_name
	if tok:is_match("ident", { buf = "infix" }) then
		tok:expect("ident", { buf = "operator" })
		operator_kind = "infix"
		operator = tok:expect("ident", { symbolic = true })
	elseif tok:is_match("ident", { buf = "prefix" }) then
		tok:expect("ident", { buf = "operator" })
		operator_kind = "prefix"
		operator = tok:expect("ident", { symbolic = true })
	elseif tok:is_match("ident", { buf = "postfix" }) then
		tok:expect("ident", { buf = "operator" })
		operator_kind = "postfix"
		operator = tok:expect("ident", { symbolic = true })
	end
	if operator then
		operator_name = operator.buf
	end
	
	tok:expect("ident", { buf = "fun"})
	local name = tok:expect("ident").buf
	
	local generics
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	local args = parse_args(tok)
	
	local throws
	if tok:is("throws") then
		throws = parse_throws(tok)
	end
	
	local returns
	if tok:is_match("->") then
		returns = parse_expr(tok)
	end
	
	local where
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	local body
	if not tok:is_done() and not tok:is("\n") then
		body = parse_block_expr(tok)
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "fun",
		operator_kind = operator_kind,
		operator = operator_name,
		name = name,
		generics = generics,
		args = args,
		throws = throws,
		returns = returns,
		where = where,
		body = body,
		span = tok:endspan()
	}
end

function parse_init(tok)	
	tok:span()
	tok:expect("ident", { buf = "init" })
	
	local generics
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	local args = parse_args(tok)
	
	local lifetimes
	if tok:is("'") then
		lifetimes = parse_lifetimes(tok)
	end
	
	local throws
	if tok:is("throws") then
		throws = parse_throws(tok)
	end
	
	local where
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	local body
	if not tok:is("\n") then
		body = parse_block_expr(tok)
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "init",
		generics = generics,
		args = args,
		lifetimes = lifetimes,
		throws = throws,
		body = body,
		span = tok:endspan()
	}
end

function parse_struct(tok)
	tok:span()
	tok:expect("ident", { buf = "struct" })
	
	local name = tok:expect("ident", { symbolic = false }).buf
	local generics
	local superlist
	local where
	local decls = {}
	
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	if tok:is(":") then
		superlist = parse_superlist(tok)
	end
	
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	if tok:match("{") then
		tok:drain("\n")
		while not tok:match("}") do
			tok:drain("\n")
			add(decls, parse_decl(tok))
		end
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "struct",
		name = name,
		generics = generics,
		superlist = superlist,
		where = where,
		decls = decls,
		span = tok:endspan()
	}
end

function parse_annotation(tok)
	tok:span()
	tok:expect("ident", { buf = "annotation" })
	
	local name = tok:expect("ident", { symbolic = false }).buf
	local generics
	local superlist
	local where
	local decls = {}
	
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	if tok:is(":") then
		superlist = parse_superlist(tok)
	end
	
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	if tok:match("{") then
		tok:drain("\n")
		while not tok:match("}") do
			tok:drain("\n")
			add(decls, parse_decl(tok))
		end
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "annotation",
		name = name,
		generics = generics,
		superlist = superlist,
		where = where,
		decls = decls,
		span = tok:endspan()
	}
end

function parse_member(tok)
	tok:span()
	tok:expect("ident", { buf = "let" })
	
	local mut = false
	local ref = false
	local name
	local ty
	local default
	
	if tok:match("ident", { buf = "mut" }) then
		mut = true
	end
	
	if tok:match("ident", { buf = "&" }) then
		ref = true
	end
	
	name = tok:expect("ident", { symbolic = false }).buf
	
	tok:expect(":")
	ty = parse_expr(tok, nil, "=")
	
	if tok:match("ident", { buf = "=" }) then
		default = parse_expr(tok)
	end
	
	return declnode {
		kind = "member",
		mut = mut,
		ref = ref,
		name = name,
		type = ty,
		default = default,
		span = tok:endspan()
	}
end

function parse_object(tok)
	tok:span()
	tok:expect("ident", { buf = "object" })
	
	local name = tok:expect("ident", { symbolic = false }).buf
	local generics
	local superlist
	local where
	local decls = {}
	
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	if tok:is(":") then
		superlist = parse_superlist(tok)
	end
	
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	if tok:match("{") then
		tok:drain("\n")
		while not tok:match("}") do
			tok:drain("\n")
			add(decls, parse_decl(tok))
		end
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "object",
		name = name,
		generics = generics,
		superlist = superlist,
		where = where,
		decls = decls,
		span = tok:endspan()
	}
end

function parse_enum(tok)
	tok:span()
	tok:expect("ident", { buf = "enum" })
	
	local name = tok:expect("ident", { symbolic = false }).buf
	local generics
	local superlist
	local where
	local cases = {}
	local decls = {}
	
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	if tok:is(":") then
		superlist = parse_superlist(tok)
	end
	
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	if tok:match("{") then
		while not tok:match("}") do
			tok:drain("\n")
			
			local token = tok:peek()
			if
				token.sym == "ident" and
				token.buf[1] >= "A" and
				token.buf[1] <= "Z"
			then
				repeat
					local casename = tok:expect("ident", { symbolic = false }).buf
					local tuple
					local raw
					
					if tok:is("(") then
						tuple = parse_paren_expr(tok)
						if (not tuple.kind == "tuple") tok:throw "expected a tuple"
					end
					
					if tok:match("ident", { buf = "=" }) then
						raw = parse_expr(tok)
					end
					
					add(cases, {
						name = casename,
						tuple = tuple,
						raw = raw
					})
				until not tok:match(",")
				tok:drain("\n")
			else
				add(decls, parse_decl(tok))
			end
		end
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "enum",
		name = name,
		generics = generics,
		superlist = superlist,
		where = where,
		cases = cases,
		decls = decls,
		span = tok:endspan()
	}
end

function parse_category(tok)
	tok:span()
	tok:expect("ident", { buf = "category" })
	
	local name = tok:expect("ident", { symbolic = false }).buf
	local generics
	local superlist
	local where
	local decls, expr
	
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	if tok:is(":") then
		superlist = parse_superlist(tok)
	end
	
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	if tok:match("{") then
		tok:drain("\n")
		
		decls = {}
		
		while not tok:match("}") do
			tok:drain("\n")
			add(decls, parse_decl(tok))
		end
	elseif tok:match("ident", { buf = "="}) then
		expr = parse_expr(tok)
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "category",
		name = name,
		generics = generics,
		superlist = superlist,
		where = where,
		decls = decls,
		expr = expr,
		span = tok:endspan()
	}
end

function parse_ext(tok)
	tok:span()
	tok:expect("ident", { buf = "extend" })
	
	local target = parse_expr(tok)
	local superlist
	local where
	local decls
	
	if tok:is(":") then
		superlist = parse_superlist(tok)
	end
	
	if tok:is("ident", { buf = "where" }) then
		where = parse_where(tok)
	end
	
	if tok:match("{") then
		tok:drain("\n")
		
		decls = {}
		
		while not tok:match("}") do
			tok:drain("\n")
			add(decls, parse_decl(tok))
		end
	end
	
	tok:drain("\n")
	
	return declnode {
		kind = "extension",
		target = target,
		superlist = superlist,
		where = where,
		decls = decls,
		span = tok:endspan()
	}
end

-- Parses type aliases.
function parse_type(tok)
	tok:span()
	tok:expect("ident", { buf = "type" })
	
	local name = tok:expect("ident").buf
	
	local generics
	if tok:is("ident", { buf = "<" }) then
		generics = parse_generics(tok)
	end
	
	tok:expect("ident", { buf = "=" })
	
	local value = parse_expr(tok)
	
	return declnode {
		kind = "type",
		name = name,
		generics = generics,
		value = value,
		span = tok:endspan()
	}
end

function parse_class(tok)
	error "classes are not specified yet"
end

function parse_args(tok)
	tok:expect("(")
	
	local args = {}
	
	if tok:match(")") then
		return args
	end
	
	do
		local token = tok:peek()
		
		if token.sym == "ident" and
			(token.buf == "mut" or token.buf == "&" or token.buf == "self")
		then
			local mut = false
			local ref = false
			local ty
			
			if tok:match("ident", { buf = "mut" }) then
				mut = true
			end
			if tok:match("ident", { buf = "&" }) then
				ref = true
			end
			
			local self_token = tok:expect("ident", { buf = "self" })
			
			if tok:match(":") then
				if (mut or ref) tok:throw "typed self combined with shorthand binding"
				
				if tok:match("ident", { buf = "mut" }) then
					mut = true
				end
				if tok:match("ident", { buf = "&" }) then
					ref = true
				end
				
				ty = parse_expr(tok)
			end
			
			if tok:match(",") then
				if (tok:is(")")) tok:throw "trailing comma"
			end
			
			add(args, {
				label = "_",
				name = "self",
				mut = mut,
				ref = ref,
				lazy = false,
				type = ty or parse_expr(tokenize("Self", span(self_token))),
				default = nil
			})
		end
	end
	
	if tok:match(")") then
		return args
	end
	
	while true do
		tok:match("\n")
		
		local label
		local name
		local lazy = false
		local mut = false
		local ref = false
		local ty
		local default
		
		if tok:match("_") then
			label = "_"
			name = "_"
		end
		
		if not tok:is(":") then
			if label then
				name = tok:expect("ident").buf
			else
				label = tok:expect("ident").buf
				if tok:is(":") then
					name = label
				else
					name = tok:expect("ident").buf
				end
			end
		end
		
		tok:expect(":")
		
		if tok:match("ident", { buf = "lazy" }) then
			lazy = true
		end
		if tok:match("ident", { buf = "mut" }) then
			mut = true
		end
		if tok:match("ident", { buf = "&" }) then
			ref = true
		end
		
		ty = parse_expr(tok, nil, "=")
		
		if tok:match("ident", { buf = "=" }) then
			default = parse_expr(tok)
		end
		
		add(args, {
			label = label,
			name = name,
			mut = mut,
			ref = ref,
			lazy = lazy,
			type = ty,
			default = default
		})
		
		if (not tok:match(",")) break
	end
	
	tok:match("\n")
	tok:expect(")")
	
	return args
end

function parse_generics(tok)
	tok:expect("ident", { buf = "<" })
	
	local params = {}
	
	repeat
		tok:match("\n")
		
		local kind
		local label
		local name
		local ty
		local default
		
		if tok:match("ident", { buf = "let" }) then
			kind = "value"
			
			if tok:match("_") then
				label = "_"
				name = tok:expect("ident", { symbolic = false }).buf
				tok:expect(":")
				ty = parse_expr(tok, nil, "=")
			else
				label = tok:expect("ident", { symbolic = false }).buf
				
				name = label
				
				if not tok:is(":") then
					name = tok:expect("ident").buf
				end
				
				tok:expect(":")
				ty = parse_expr(tok, nil, "=")
			end
		else
			kind = "type"
			
			name = tok:expect("ident").buf
			if tok:match(":") then
				label = name
				name = tok:expect("ident").buf
			end
		end
		
		if tok:match("ident", { buf = "=" }) then
			default = parse_expr(tok)
		end
		
		add(params, {
			kind = kind,
			label = label,
			name = name,
			type = ty,
			default = default
		})
	until not tok:match(",")
	
	tok:match("\n")
	tok:expect("ident", { buf = ">" })
	
	return params
end

-- A super list is the inheritance-like list
-- used by structs, enums and classes.
-- For example: enum A: Int, SomeCategory
function parse_superlist(tok)
	tok:expect(":")
	local superlist = {}
	repeat add(superlist, parse_expr(tok)) until not tok:match(",")
	return superlist
end

-- A where list defines constraints and refinements
-- of a declaration.
-- For example:
-- struct A<const count: Integer, T>
-- where T: Copyable, count > 0
function parse_where(tok)
	tok:expect("ident", { buf = "where" })
	
	local constrs = {}
	local exprs = {}
	
	repeat
		tok:match("\n")
		if tok:is("ident") and tok:peek(2).sym == ":" then
			local name = tok:expect("ident", { symbolic = false })
			tok:expect(":")
			local expr = parse_expr(tok)
			add(constrs, {
				name = name,
				expr = expr
			})
		else
			add(exprs, parse_expr(tok))
		end
	until not tok:match(",")
	
	return { constrs = constrs, exprs = exprs }
end

function parse_throws(tok)
	tok:expect("ident", { buf = "throws" })
	local except = {}
	
	repeat
		tok:match("\n")
		add(except, parse_expr(tok))
	until not tok:match(",")
	
	return except
end

local precedence = {
	["="]  = 0,

	["or"] = 1,
	["and"] = 2,
	
	["||"] = 1,
	["&&"] = 2,
	
	["|"]  = 3,
	["^"]  = 4,
	["&"]  = 5,
	
	["=="] = 6,
	["!="] = 6,
	
	["<"]  = 7,
	["<="] = 7,
	[">"]  = 7,
	[">="] = 7,
	
	["+"]  = 8,
	["-"]  = 8,
	
	["*"]  = 9,
	["/"]  = 9,
	["%"]  = 9
}

local custom_infix_prec = 10
local prefix_prec = 1000

local right_assoc = {
	["="] = true
}

function is_right_assoc(op)
	return right_assoc[op.buf] ~= nil
end

function is_left_assoc(op)
	return not is_right_assoc(op)
end

function infix_precedence(op)
	return precedence[op.buf] or custom_infix_prec
end

function operator_role(op)
	assert(op.symbolic or op.buf == "and" or op.buf == "or")
	
	if op.buf == "and" or op.buf == "or" then
		return "infix"
	end
	
	local l = op.leading_ws
	local r = op.trailing_ws
	
	if l and r then
		return "infix"
	elseif l and not r then
		return "prefix"
	elseif r and not l then
		return "postfix"
	elseif string.find(op.buf, "%.") then
		-- Special case for range operators"
		return "infix"
	else
		return "invalid"
	end
end

-- Expression node constructor which is useful for adding
-- a default string conversion for the expression tree.
function exprnode(v)
	return setmetatable(v, {
		__tostring = exprstr
	})
end

function exprstr(node)
	if node.kind == "wildcard" then
		return "_"
	elseif node.kind == "not" then
		return "(not " .. tostring(node.rhs) ..")"
	elseif node.kind == "binary" then
		return
			"(" .. node.op .. " " ..
			tostring(node.lhs) .. " " ..
			tostring(node.rhs) .. ")"
	elseif node.kind == "number" then
		return tostring(node.value)
	elseif node.kind == "string" then
		return "\"" .. node.value .. "\""
	elseif node.kind == "boolean" then
		return tostring(node.value)
	elseif node.kind == "intrinsic" then
		return "#" .. node.name
	elseif node.kind == "prefix" then
		return
			"(pre:" .. node.op .. " " ..
			tostring(node.rhs) .. ")"
	elseif node.kind == "postfix" then
		return
			"(post:" .. node.op .. " " ..
			tostring(node.lhs) .. ")"
	elseif node.kind == "tuple" then
		local parts = {}
		
		for element in all(node.elements) do
			if element.label then
				add(parts, element.label .. ":" .. tostring(element.value))
			else
				add(parts, tostring(element.value))
			end
		end
	
		return "(" .. table.concat(parts, ", ") .. ")"
	elseif node.kind == "call" then
		local args = {}
		
		for arg in all(node.args) do
			if arg.label then
				add(args, arg.label .. ":" .. tostring(arg.value))
			else
				add(args, tostring(arg.value))
			end
		end
		
		return tostring(node.callee) .. "(" .. table.concat(args, ", ") .. ")"
	elseif node.kind == "subscript" then
		local args = {}
		
		for arg in all(node.args) do
			if arg.label then
				add(args, arg.label .. ":" .. tostring(arg.value))
			else
				add(args, tostring(arg.value))
			end
		end
		
		return tostring(node.callee) .. "[" .. table.concat(args, ", ") .. "]"
	elseif node.kind == "block" then
		local exprs = {}
		
		for expr in all(node.exprs) do
			add(exprs, tostring(expr))
		end
		
		return "{ " .. table.concat(exprs, "; ") .. " }"
	elseif node.kind == "generics" then
		local params = {}
		
		for param in all(node.params) do
			if param.label then
				add(params, param.label .. ":" .. tostring(param.value))
			else
				add(params, tostring(param.value))
			end
		end
		
		return tostring(node.callee) .. "<" .. table.concat(params, ", ") .. ">"
	elseif node.kind == "list" then
		local values = {}
		
		for value in all(node.values) do
			add(values, tostring(value))
		end
		
		return "[ " .. table.concat(values, ", ") .. " ]"
	elseif node.kind == "ident" then
		return node.name
	elseif node.kind == "unsafe" then
		return "(unsafe " .. tostring(node.rhs) .. ")"
	elseif node.kind == "return" then
		if node.rhs then
			return "(return " .. tostring(node.rhs) .. ")"
		else
			return "(return )"
		end
	elseif node.kind == "throw" then
		return "(throw " .. tostring(node.rhs) .. ")"
	elseif node.kind == "await" then
		return "(await " .. tostring(node.rhs) .. ")"
	elseif node.kind == "member" then
		return tostring(node.lhs) .. "." .. node.name
	elseif node.kind == "if" then
		if not node.else_body then
			return "(if " .. tostring(node.pat) .. " then " ..
				tostring(node.body) .. ")"
		else
			return "(if " .. tostring(node.pat) .. " then " ..
				tostring(node.body) .. " else " ..
				tostring(node.else_body) .. ")"
		end
	elseif node.kind == "guard" then
		return "(guard " .. tostring(node.pat) .. " else " ..
			tostring(node.else_body) .. ")"
	elseif node.kind == "when" then
		return "(when " .. tostring(node.pat) .. ")"
	elseif node.kind == "pattern" then
		local buf = ""
		
		if node.expr then
			buf ..= tostring(node.expr)
		end
		
		if node.case then
			buf ..= ("." .. node.case)
		end
		
		if node.elems then
			buf ..= ""
			
			local elems = {}
			for elem in all(node.elems) do
				add(elems, tostring(elem))
			end
			
			buf ..= ("(" .. table.concat(elems, ", ") .. ")")
		end
		
		if node.rhs then
			buf ..= (" = " .. tostring(node.rhs))
		end
		
		if node.where then
			buf ..= (" where " .. tostring(node.where))
		end
		
		if node.expr then
			return buf
		else
			return "(pat " .. buf .. ")"
		end
	elseif node.kind == "while" then
		return "(while " .. tostring(node.pat) .. " do " ..
			tostring(node.body) .. ")"
	elseif node.kind == "memberinfer" then
		return "." .. tostring(node.rhs)
	elseif node.kind == "break" then
		local buf = {}
		
		if (node.label)	add(buf, ":" .. node.label)
		if (node.rhs) add(buf, tostring(node.rhs))
		
		return "(break " .. table.concat(buf, " ") .. ")"
	elseif node.kind == "loop" then
		return "(loop " .. tostring(node.body) .. ")"
	elseif node.kind == "match" then
		local arms = {}
		
		for arm in all(node.arms) do
			add(arms, tostring(arm.pat) .. " -> " .. tostring(arm.body))
		end
		
		return "(match " .. tostring(node.lhs) .. " { " ..
			table.concat(arms, "; ") .. " })"
	elseif node.kind == "catch" then
		local arms = {}
		
		for arm in all(node.arms) do
			add(arms,
				arm.name .. ":" ..
				tostring(arm.type) .. " -> " ..
				tostring(arm.body)
			)
		end
		
		return "(catch " .. tostring(node.lhs) .. " { " ..
			table.concat(arms, "; ") .. " })"
	elseif node.kind == "closure" then
		local args = {}
		
		for arg in all(node.args) do
			local buf = ""
			if (arg.mut) buf ..= "mut "
			if (arg.ref) buf ..= "&"
			buf ..= arg.name
			if (arg.type) buf ..= (":" .. tostring(arg.type))
			add(args, buf)
		end
		
		return "(|" .. table.concat(args, ", ") .. "| " ..
			tostring(node.body) .. ")"
	elseif node.kind == "binding" then
		local buf = "(let "
		
		if (node.mut) buf ..= "mut "
		if (node.ref) buf ..= "&"
		buf ..= node.name
		if (node.type) buf ..= (":" .. tostring(node.type))
		
		return buf .. " " .. tostring(node.rhs) .. ")"
	elseif node.kind == "pattern_binding" then
		local buf = "let "
		
		if (node.mut) buf ..= "mut "
		if (node.ref) buf ..= "&"
		buf ..= node.name
		if (node.type) buf ..= (":" .. tostring(node.type))
		
		return buf
	elseif node.kind == "member" then
		return "todo"
	elseif node.kind == "ref" then
		return "todo"
	elseif node.kind == "meta" then
		return "todo"
	elseif node.kind == "lifetime" then
		return "todo"
	else
		return "<?expr:" .. tostring(node.kind) .. ">"
	end
end

-- The most fundamental part of the parser, as near
-- all language constructs are fully or partially composed
-- from expressions.
--
-- Since the language allows arbitrary operators in
-- prefix, infix and postfix positions there has to be a way
-- to tell them apart. Taking inspiration from Swift, the solution
-- is to remember the whitespace around symbolic identifiers.
-- Spacing on both sides is an infix operator,
-- otherwise the operator is associated in the direction where
-- there is no whitespace. No spacing at all is not valid grammar.
-- The postfix "<" is also reserved for generics.
--
-- Arbitrary infix operators also mean that precedence could become a mess.
-- For this reason precedence is defined by symbol convention as seen
-- in C and most other languages nowadays. Custom operators get the strongest
-- binding of all operators and share it with left associativity.
-- Unusual operators are a rarely useful feature and allowing customization
-- of these attributes is not worth the extreme inefficiency as seen in Swift
-- which on my M2 Max takes half a second to compile a single line
-- normalization function if written in one clean expression derived from the formula.
function parse_expr(tok, min_prec, exclude_op)
	min_prec = min_prec or 0
	
	local lhs = parse_postfix_expr(parse_prefix_expr(tok), tok)
	
	while true do
		local op = tok:peek()
		if (not op)	break
		if (not op.symbolic and op.buf ~= "and" and op.buf ~= "or") break
		if 	(operator_role(op) ~= "infix") break
		if (op.buf == exclude_op) break
		
		local prec = infix_precedence(op)
		if (prec < min_prec) break
		
		tok:consume()
		
		local next_min = prec + (is_left_assoc(op) and 1 or 0)
		local rhs = parse_expr(tok, next_min)
		
		lhs = exprnode {
			kind = "binary",
			op = op.buf,
			lhs = lhs,
			rhs = rhs,
			span = span(lhs.span.first, rhs.span.last)
		}
	end
	
	return lhs
end

-- A utility parser which can resolve labeled lists, for example
-- call arguments, subscript arguments, or generic parameters.
function parse_labeled_element(tok, first_expr)
	if tok:peek() and tok:peek().sym == ":" then
		tok:consume()
		
		local val = parse_expr(tok)
		
		return {
			label = first_expr.name,
			value = val
		}
	else
		return {
			label = nil,
			value = first_expr
		}
	end
end

function parse_prefix_expr(tok)
	tok:span()
	
	local token = tok:peek()
	
	if not token then
		tok:throw "unexpected end of source"
	end
	
	if token.sym == "ident" and token.buf == "mut" then
		tok:consume()
		tok:expect("ident", { buf = "&" })
		return exprnode {
			kind = "ref",
			mut = true,
			rhs = parse_expr(tok),
			span = tok:endspan()
		}
	end
	if token.sym == "ident" and token.buf == "&" then
		tok:consume()
		return exprnode {
			kind = "ref",
			mut = false,
			rhs = parse_expr(tok),
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "not" then
		tok:consume()
		return exprnode {
			kind = "not",
			rhs = parse_expr(tok, prefix_prec),
			span = tok:endspan()
		}
	end
	
	if token.sym == "#" then
		tok:consume()
		return exprnode {
			kind = "intrinsic",
			name = tok:expect("ident").buf,
			span = tok:endspan()
		}
	end
	
	if token.sym == "_" then
		tok:consume()
		return exprnode {
			kind = "wildcard",
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "true" then
		tok:consume()
		return exprnode {
			kind = "boolean",
			value = true,
			span = tok:endspan()
		}
	end
	if token.sym == "ident" and token.buf == "false" then
		tok:consume()
		return exprnode {
			kind = "boolean",
			value = false,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "let" then
		tok:consume()
		
		if not tok:is("(") then
			local mut = false
			local ref = false
			local ty
			local rhs
			local name
			
			if tok:match("ident", { buf = "mut"}) then
				mut = true
			end
			if tok:match("ident", { buf = "&"}) then
				ref = true
			end
			
			name = tok:expect("ident", { symbolic = false }).buf
			
			if tok:match(":") then
				ty = parse_expr(tok, nil, "=")
			end
			
			tok:expect("ident", { buf = "="})
			
			rhs = parse_expr(tok)
			
			return exprnode {
				kind = "binding",
				mut = mut,
				ref = ref,
				name = name,
				type = ty,
				rhs = rhs,
				span = tok:endspan()
			}
		else
			tok:throw "destructuring is not implemented"
		end
	end
	
	if token.sym == "ident" and token.buf == "loop" then
		tok:consume()
		local expr = parse_expr(tok, prefix_prec)
		return exprnode {
			kind = "loop",
			body = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "while" then
		tok:consume()
		local pat = parse_pattern(tok)
		
		local body
		if tok:match("ident", { buf = "do" }) then
			body = parse_expr(tok, prefix_prec)
		else
			body = parse_block_expr(tok)
		end
		
		return exprnode {
			kind = "while",
			pat = pat,
			body = body,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "unsafe" then
		tok:consume()
		local expr = parse_expr(tok)
		return exprnode {
			kind = "unsafe",
			rhs = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "return" then
		tok:consume()
		local expr
		
		if not tok:is_done() and not tok:is("\n") then
			expr = parse_expr(tok)
		end
		
		return exprnode {
			kind = "return",
			rhs = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "throw" then
		tok:consume()
		local expr = parse_expr(tok)
		return exprnode {
			kind = "throw",
			rhs = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "await" then
		tok:consume()
		local expr = parse_expr(tok)
		return exprnode {
			kind = "await",
			rhs = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "." then
		tok:consume()
		local expr = parse_expr(tok, prefix_prec)
		return exprnode {
			kind = "memberinfer",
			rhs = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "break" then
		tok:consume()
		
		local label
		if tok:match(":") then
			label = tok:expect("ident").buf
		end
		
		local expr
		if not tok:is_done() and not tok:is("\n") then
			 expr = parse_expr(tok)
		end
		
		return exprnode {
			kind = "break",
			label = label,
			rhs = expr,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "if" then
		tok:consume()
		local pat = parse_pattern(tok)
		
		local body
		if tok:match("ident", { buf = "then" }) then
			body = parse_expr(tok)
		else
			body = parse_block_expr(tok)
		end
		
		local else_body
		if tok:match("ident", { buf = "else" }) then
			-- else if is handled inherently, it's just
			-- another ternary if nested as the else expression.
			-- This is recursive but one should not use many
			-- branches like this anyway, that's what the symmetrical
			-- and more optimizable match expressions are for.
			else_body = parse_expr(tok)
		end
		
		return exprnode {
			kind = "if",
			pat = pat,
			body = body,
			else_body = else_body,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "guard" then
		tok:consume()
		local pat = parse_pattern(tok)
		
		local else_body
		if tok:expect("ident", { buf = "else" }) then
			-- else if is handled inherently, it's just
			-- another ternary if nested as the else expression.
			-- This is recursive but one should not use many
			-- branches like this anyway, that's what the symmetrical
			-- and more optimizable match expressions are for.
			else_body = parse_expr(tok)
		end
		
		return exprnode {
			kind = "guard",
			pat = pat,
			else_body = else_body,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and token.buf == "when" then
		tok:consume()
		local pat = parse_pattern(tok)
		
		return exprnode {
			kind = "when",
			pat = pat,
			span = tok:endspan()
		}
	end
	
	if token.sym == "{" then
		return parse_block_expr(tok)
	end
	
	if token.sym == "number" then
		tok:consume()
		return exprnode {
			kind = "number",
			value = token.buf,
			span = tok:endspan()
		}
	end
	
	if token.sym == "str" then
		tok:consume()
		return exprnode {
			kind = "string",
			value = token.buf,
			span = tok:endspan()
		}
	end
	
	if token.sym == "(" then
		return parse_paren_expr(tok)
	end
	
	if token.sym == "[" then
		tok:consume()
		
		local values = {}
		
		if not tok:is("]") then
			repeat
				tok:drain("\n")
				add(values, parse_expr(tok))
			until not tok:is_match(",")
		end
		
		tok:expect("]")
		
		return exprnode {
			kind = "list",
			values = values,
			span = tok:endspan()
		}
	end
	
	if token.sym == "ident" and (token.buf == "|" or token.buf == "||") then
		tok:consume()
		
		local args = {}
		local captures = {}
		
		if token.buf == "|" then
			while true do
				local mut = false
				local ref = false
				
				if tok:match("ident", { buf = "mut" }) then
					mut = true
				end
				
				if tok:match("ident", { buf = "&" }) then
					ref = true
				end
				
				local name = tok:expect("ident").buf
				local ty
				
				if tok:match(":") then
					ty = parse_expr(tok)
				end
				
				add(args, {
					name = name,
					mut = mut,
					ref = ref,
					type = ty
				})
				
				if tok:match("ident", { buf = "|" }) then
					break
				else
					tok:expect(",")
				end
			end
		end
		
		--[[
		if tok:match("ident", { buf = "<" }) then
			-- generics
		end
		
		if tok:match("[", { leading_ws = false }) then
			-- captures
		end
		]]--
		
		local body = parse_expr(tok)
		
		return exprnode {
			kind = "closure",
			args = args,
			body = body,
			span = tok:endspan()
		}
	end
	
	if
		token.sym == "ident" and
		token.symbolic and
		operator_role(token) == "prefix" and
		not (token.buf == "<")
	then
		tok:consume()
		
		local rhs = parse_expr(tok, prefix_prec)
		
		return exprnode {
			kind = "prefix",
			op = token.buf,
			rhs = rhs,
			span = tok:endspan()
		}
	elseif token.sym == "ident" then
		tok:consume()
		return exprnode {
			kind = "ident",
			name = token.buf,
			span = tok:endspan()
		}
	end
	
	tok:throw "expected expression"
end

function parse_postfix_expr(lhs, tok)
	while true do
		local token = tok:peek()
		if not token then break end
		
		if token.sym == "'" then
			local lifetimes, last_token = parse_lifetimes(tok)
			lhs = exprnode {
				kind = "lifetime",
				lhs = lhs,
				lifetimes = lifetimes,
				span = span(lhs.span.first, last_token)
			}
		elseif token.sym == "(" then
			tok:consume()
			local args = {}
			
			if not tok:is(")") then
				local first = parse_expr(tok)
				add(args, parse_labeled_element(tok, first))
				
				while tok:peek() and tok:peek().sym == "," do
					tok:consume()
					
					if (tok:peek().sym == ")") break
					
					local expr = parse_expr(tok)
					add(args, parse_labeled_element(tok, expr))
				end
			end
			
			local closing = tok:expect(")")
			
			lhs = exprnode {
				kind = "call",
				callee = lhs,
				args = args,
				span = span(lhs.span.first, closing)
			}
		elseif token.sym == "." then
			tok:consume()
			local member = tok:expect("ident")
			lhs = exprnode {
				kind = "member",
				lhs = lhs,
				name = member.buf,
				span = span(lhs.span.first, member)
			}
		elseif token.sym == ":" and tok:peek(2) and tok:peek(2).sym == ":" then
			tok:consume(2)
			local member = tok:expect("ident")
			lhs = exprnode {
				kind = "meta",
				lhs = lhs,
				name = member.buf,
				span = span(lhs.span.first, member)
			}
		elseif token.sym == "[" then
			tok:consume()
			local args = {}
			
			local first = parse_expr(tok)
			add(args, parse_labeled_element(tok, first))
			
			while tok:peek() and tok:peek().sym == "," do
				tok:consume()
				
				if (tok:peek().sym == "]") break
				
				local expr = parse_expr(tok)
				add(args, parse_labeled_element(tok, expr))
			end
			
			local closing = tok:expect("]")
			
			lhs = exprnode {
				kind = "subscript",
				callee = lhs,
				args = args,
				span = span(lhs.span.first, closing)
			}
		elseif token.sym == "ident" and token.buf == "match" then
			tok:consume()
			
			tok:expect("{")
			tok:match("\n")
			
			local arms = {}
			
			while not tok:is("}") do
				tok:drain("\n")
				if (tok:is("}")) break
				
				local pat = parse_pattern(tok)
				
				tok:expect("->")
				
				local body = parse_expr(tok)
				
				add(arms, {
					pat = pat,
					body = body
				})
				
				if not tok:drain("\n") then
					tok:match(";")
				end
			end
			
			local closing = tok:expect("}")
			
			lhs = exprnode {
				kind = "match",
				lhs = lhs,
				arms = arms,
				span = span(lhs.span.first, closing)
			}
		elseif token.sym == "ident" and token.buf == "catch" then
			tok:consume()
			
			tok:expect("{")
			tok:match("\n")
			
			local arms = {}
			
			while not tok:is("}") do
				tok:drain("\n")
				if (tok:is("}")) break
				
				local name = tok:expect("ident").buf
				
				tok:expect(":")
				
				local ty = parse_expr(tok)
				
				tok:expect("->")
				
				local body = parse_expr(tok)
				
				add(arms, {
					name = name,
					type = ty,
					body = body
				})
				
				if not tok:drain("\n") then
					tok:match(";")
				end
			end
			
			local closing = tok:expect("}")
			
			lhs = exprnode {
				kind = "catch",
				lhs = lhs,
				arms = arms,
				span = span(lhs.span.first, closing)
			}
		elseif token.sym == "ident" and token.buf == "<" then
			tok:consume()
			local params = {}
			
			local first = parse_expr(tok)
			add(params, parse_labeled_element(tok, first))
			
			while tok:peek() and tok:peek().sym == "," do
				tok:consume()
				
				local p = tok:peek()
				if (p.sym == "ident" and p.buf == ">") break
				
				local expr = parse_expr(tok)
				add(params, parse_labeled_element(tok, expr))
			end
			
			local closing = tok:expect("ident", { buf = ">" })
			
			lhs = exprnode {
				kind = "generics",
				callee = lhs,
				params = params,
				span = span(lhs.span.first, closing)
			}
		elseif
			token.sym == "ident" and
			token.symbolic and
			operator_role(token) == "postfix" and
			token.buf ~= "|" and
			token.buf ~= ">"
		then
			tok:consume()
			lhs = exprnode {
				kind = "postfix",
				op = token.buf,
				lhs = lhs,
				span = span(lhs.span.first, token)
			}
		else
			break
		end
	end
	
	return lhs
end

function parse_paren_expr(tok)
	tok:span()
	tok:consume()
	
	-- The special case of an empty tuple.
	if tok:peek().sym == ")" then
		tok:consume()
		
		return exprnode {
			kind = "tuple",
			elements = {},
			span = tok:endspan()
		}
	end
	
	local first = parse_expr(tok)
	
	-- Detect tuples.
	if tok:peek() and (tok:peek().sym == "," or tok:peek().sym == ":") then
		local elements = {}
		
		add(elements, parse_labeled_element(tok, first))
		
		while tok:peek() and tok:peek().sym == "," do
			tok:consume()
			
			if (tok:peek().sym == ")") break
			
			local expr = parse_expr(tok)
			add(elements, parse_labeled_element(tok, expr))
		end
		
		tok:expect(")")
		
		return exprnode {
			kind = "tuple",
			elements = elements,
			span = tok:endspan()
		}
	end
	
	tok:expect(")")
	
	return first
end

function parse_block_expr(tok)
	tok:span()
	tok:expect("{")
	tok:drain("\n")
	
	local exprs = {}
	
	while not tok:is("}") do
		tok:drain("\n")
		
		add(exprs, parse_expr(tok))
		
		if tok:is("\n") or tok:is(";") then
			tok:consume()
			tok:drain("\n")
		else
			break
		end
	end
	
	tok:expect("}")
	
	return exprnode {
		kind = "block",
		exprs = exprs,
		span = tok:endspan()
	}
end

-- A specialized parser for binding patterns, which handles
-- all pattern matching in the language.
function parse_pattern(tok)
	tok:span() -- todo: the spans in here are all sorts of wrong.
	
	local case
	local elems
	local expr
	local rhs
	local where
	
	if tok:match(".") then
		case = tok:expect("ident", { symbolic = false }).buf
	end
	
	if tok:match("(") then
		elems = {}
		
		repeat
			if tok:match("_") then
				add(elems, exprnode {
					kind = "wildcard"
				})
			elseif tok:match("ident", { buf = "let" }) then
				tok:span()
				
				local mut = false
				local ref = false
				local ty
				local name
				
				if tok:match("ident", { buf = "mut" }) then
					mut = true
				end
				
				if tok:match("ident", { buf = "&" }) then
					ref = true
				end
				
				name = tok:expect("ident", { symbolic = false }).buf
				
				if tok:match(":") then
					ty = parse_expr(tok)
				end
				
				add(elems, exprnode {
					kind = "pattern_binding",
					mut = mut,
					ref = ref,
					type = ty,
					name = name,
					span = tok:endspan()
				})
			else
				add(elems, parse_pattern(tok))
			end
		until not tok:match(",")
		tok:expect(")")
	end
	
	if not case and not elems then
		expr = parse_expr(tok)
	end
	
	if tok:match("ident", { buf = "=" }) then
		rhs = parse_expr(tok)
	end
	
	if tok:match("ident", { buf = "where" }) then
		where = parse_expr(tok)
	end
	
	return exprnode {
		kind = "pattern",
		case = case,
		elems = elems,
		expr = expr,
		rhs = rhs,
		where = where,
		span = tok:endspan()
	}
end

function parse_destructuring(tok)
	tok:throw "todo"
end

-- Normally lifetimes are just a postfix expression,
-- but sometimes they are placed uniquely, such as in initializers.
function parse_lifetimes(tok)	
	local lifetimes = {}
	
	local token
	while tok:is("'") do
		token = tok:match("'")
		add(lifetimes, tok:expect("ident", { symbolic = false }).buf)
	end
	
	return lifetimes, token
end

-- Sema -------------------------------------------------------------------------------

function evaluator(sir, namespace, source, realm, overload)
	local ctx = {
		sir = sir,
		namespace = namespace,
		source = source,
		overload = overload,
		realm = realm, -- The expected realm ("type"/"value"/nil).
		lexical_stack = {}, -- Lexical state.
		evaluating = {} -- Cycle detection.
	}
	
	local function constval(realm, typ, data)
		assert(realm == "type" or realm == "value" or realm == "residual")
		assert(typ)
		return {
			realm = realm,
			type = typ,
			data = data
		}
	end
	
	local function errval(reason)
		assert(reason)
		return { realm = "error", reason = reason }
	end
	
	local metatype = { realm = "type", data = { kind = "Type" } }
	metatype.type = metatype -- cycles make serialization sad.
	
	-- Creates a new lexical scope. There isn't always a scope, for example
	-- if the expression is part of a declaration. Generally, scopes are used
	-- to handle block expressions.
	function ctx:scope(consume_boundary)
		add(self.lexical_stack, {
			-- If true then anything above this scope may not be moved
			-- through this boundary. For example, you can't consume a variable
			-- from outside a loop inside one, as past the first iteration
			-- the value would be uninitialized, which is invalid. Even if a loop
			-- provably runs only once, that is too confusing and could lead to issues
			-- where code stops compiling based on a constant change across platforms.
			-- Similarly, a non consuming closure can't consume
			-- anything from outside for obvious reasons.
			consume_boundary = consume_boundary,
			bindings = {}
		})
	end
	
	function ctx:endscope()
		-- todo: run every deinit or produce deinit residuals.
		deli(self.lexical_stack)
	end
	
	function ctx:current_scope()
		return self.lexical_stack[#self.lexical_stack]
	end
	
	-- Creates a lexical binding.
	-- Bindings can shadow prior scopes, but it is an error
	-- to redeclare the same binding in the same scope.
	function ctx:binding(name, typ, val)
		if (self:current_scope().bindings[name]) return "error"
		
		local initial_refcount
		if val == nil then
			initial_refcount = -2
		else
			initial_refcount = 0
		end
		
		self:current_scope().bindings[name] = {
			-- A lexical reference count. A value of zero is balanced,
			-- a binding not observed in any way.
			--
			-- A negative one means a mutable projection exists,
			-- nothing else can touch this binding.
			--
			-- A negative two means the value is not initialized,
			-- either initially or it was consumed.
			--
			-- A positive reference count tracks the number of borrowed projections,
			-- only other borrows are valid.
			refcount = initial_refcount,
			type = typ,
			value = val
		}
	end
	
	function ctx:todo(expr)
		self.sir:compile_error(expr,
			"unimplemented expression",
			"The expression `" .. expr.kind .. "` is not implemented."
		)
		return errval("not implemented")
	end
	
	function ctx:eval(expr)
		assert(expr)
		
		if self.evaluating[expr] then
			self.sir:compile_error(expr, "compile-time cycle")
			return errval("cycle")
		end
		
		self.evaluating[expr] = true
		
		local dispatch = self["eval_"..expr.kind]
		if not dispatch then
			self.sir:compile_error(expr,
				"unhandled expression",
				"The expression `" .. expr.kind .. "` does not have a handler."
			)
			return errval("unhandled")
		end
		local result = dispatch(self, expr)
		
		if self.realm and result.realm ~= "error" and result.realm ~= "residual" and
			result.realm ~= self.realm
		then
			self.sir:compile_error(expr,
				"unexpected expression realm",
				"Expected a " .. self.realm .. " but evaluated to a " .. result.realm .. "."
			)
			result = errval("realm mismatch")
		end
		
		self.evaluating[expr] = nil
		return result
	end
	
	function ctx:eval_number(expr)
		-- Strawberry and Lua literals share structure so we can
		-- just get Lua to parse them. That being said, we support underscore
		-- separators which Lua does not. It's probably enough to just strip those out.
		--
		-- Do note that this is a non-compliant, prototype implementation.
		-- In proper Strawberry decimal literals do actually use a binary coded
		-- decimal representation and only cast away the arbitrary precision
		-- once converted to a fixed or floating point value.
		-- Similarly, integer literals are supposed to have no limit on bit width, but
		-- the prototype is constrained to Lua integer limits.
		local str = ""
		for char in all(expr.value) do if (char ~= "_") str ..= char end
		
		local value = tonum(str)
		local ty = math.type(value)
		
		if ty == "integer" then
			return self:todo(expr)
		elseif ty == "float" then
			return self:todo(expr)
		else
			self.sir:compile_error(expr, "invalid number literal")
			return errval("invalid literal")
		end
	end
	
	function ctx:eval_string(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_boolean(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_wildcard(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_ident(expr)
		for i = #self.lexical_stack, 1, -1 do
			local scope = self.lexical_stack[i]
			
			if scope.bindings[expr.name] then
				local binding = scope.bindings[expr.name]
				
				if binding.refcount == -2 then
					-- todo: might be worth it to track an initialization tag specifically
					-- for the purpose of a unique diagnostic for use-after-consume.
					self.sir:compile_error(expr,
						"use of potentially uninitialized value",
						"Bindings need to be left initialized on all paths before use."
					)
					return errval("uninit use")
				end
				
				if binding.value.realm == "residual" then
					return constval("residual", binding.type, { "rvalue", binding })
				else
					return constval("value", binding.type, binding.value)
				end
			end
		end
		
		local sym, err = lookup_symbol(self.sir, self.namespace, expr.name, self.source)
		if err then
			assert(err.kind == "ambiguous") -- in case more errors get added?
			
			local names = {}
			for import in all(err.imports) do add(names, "`" .. import.path .. "`") end
			self.sir:compile_error(expr,
				"ambiguous identifier",
				"The identifier is visible through multiple imports:\n- "
					.. table.concat(names, "\n- ")
			)
			for import in all(err.imports) do
				self.sir:compile_info(import.ast,
					"ambiguity raised here",
					"This import introduces ambiguity for lookup of `" .. expr.name .. "`."
				)
			end
			return errval("ambiguous")
		elseif not sym then
			self.sir:compile_error(expr,
				"unresolved identifier",
				"Could not find identifier '" .. expr.name .. "' in this scope."
			)
			return errval("unresolved")
		else
			if sym.group == "types" then
				return constval("type", metatype, { kind = "common", path = sym.name })
			elseif sym.group == "categories" then
				return constval("type", metatype, { kind = "category", path = sym.name })
			elseif sym.group == "globals" then
				return self:todo(expr)
			elseif sym.group == "functions" then
				return self:todo(expr)
			elseif sym.group == "generics" then
				return self:todo(expr)
			else
				error("unexpected lookup group: " .. sym.group)
			end
		end
	end
	
	function ctx:eval_binary(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_prefix(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_postfix(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_not(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_member(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_memberinfer(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_ref(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_meta(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_subscript(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_binding(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_pattern_binding(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_if(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_when(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_guard(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_while(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_loop(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_break(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_for(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_return(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_throw(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_await(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_block(expr)
		self:scope(false)
		
		local result
		for stmt in all(expr.exprs) do
			result = self:eval(stmt)
			
			if result.realm == "error" then
				self:endscope()
				return result
			end
		end
		
		self:endscope()
		
		if not result then
			return self:todo(expr) -- return an empty tuple
		end
		
		return result
	end
	
	function ctx:eval_tuple(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_list(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_generics(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_call(expr)
		-- This is where a lot of logic will happen. We need to resolve
		-- the exact monomorphisation before we can do anything unless we are able to
		-- fully resolve the call at compile time.
		return self:todo(expr)
	end
	
	function ctx:eval_closure(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_match(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_catch(expr)
		-- This is a postfix expression to calls and other than its own logic
		-- it participates in exception monomorphization of the call.
		return self:todo(expr)
	end
	
	function ctx:eval_pattern(expr)
		return self:todo(expr)
	end
	
	function ctx:eval_unsafe(expr)
		return self:todo(expr)
	end
	
	-- This won't actually work yet because intrinsics have an undesirable
	-- structure in the AST for now and it has to be changed. Intrinsics are
	-- either a type or a call, so there is no need to allow the grammar to
	-- support anything else and force this code to deal with it.
	function ctx:eval_intrinsic(expr)
		return self:todo(expr)
		--[[
		-- todo: once fixed this code will identify intrinsic types separately.
		local dispatch = self["eval_int_"..expr.kind]
		
		if not dispatch then
			self.sir:compile_error(expr, "unknown intrinsic")
			return errval("noint")
		end
		
		local result = dispatch(self, expr)
		]]--
	end
	
	return ctx
end

--[[
-- In the context of Lua, sizes are defined as the
-- amount of variables an instance of the type requires.
-- Lua has a limited count of locals so the calling convention
-- will only use 16 of them.
function sizeof(typ)
	if
		typ.kind == "Integer" or
		typ.kind == "Decimal" or
		typ.kind == "StaticString"
	then
		return nil -- Const-only primitives.
	elseif typ.kind == "Int" then
		return 1 -- Always a Lua integer
	elseif typ.kind == "Float" then
		return 1 -- Always a Lua float
	elseif typ.kind == "Boolean" then
		return 1 -- Always a Lua boolean
	elseif typ.kind == "Struct" then
		local size = 0
		for element in all(typ.elements) do
			size += sizeof(element)
		end
		return size -- Same as tuple but nominal
	elseif typ.kind == "Enum" then
		if #typ.cases == 0 then
			return 0 -- Caseless enum, no size, not possible to materialize
		elseif #typ.cases == 1 then
			return sizeof(typ.cases[1]) -- No tag needed, only one case
		else
			local size = 0
			for case in all(typ.cases) do
				size = max(size, sizeof(case))
			end
			return sizeof(typ.tag_type) + size -- Space for biggest case and a tag
		end
	elseif typ.kind == "Tuple" then
		local size = 0
		for element in all(typ.elements) do
			size += sizeof(element)
		end
		return size -- Heterogeneous fixed size container
	elseif typ.kind == "Pointer" then
		return 1 -- Lowered to a Lua table
	elseif typ.kind == "Buffer" then
		return typ.count * sizeof(typ.element) -- Homogeneous fixed size container
	elseif typ.kind == "Object" then
		return 0 -- Not reified, objects are singletons for global category conformances
	elseif typ.kind == "Class" then
		return sizeof(typ.storage_type) -- Size of backing smart pointer
	elseif typ.kind == "Function" then
		return 1 -- A function item
	elseif typ.kind == "Closure" then
		return 1 -- We can probably have Lua take care of the captures
	elseif typ.kind == "LuaValue" then
		return 1 -- Just a target specific safe wrapper around Lua values
	end
end

function offsetof(typ, name)
	assert(typ.kind == "Struct")
	
	local offset = 0
	for element in all(typ.elements) do
		if element.name == name then
			return offset
		end
		offset += sizeof(element.type)
	end
end
]]--

-- A small utility mapping terms to their plural form for diagnostic purposes.
local plural = {
	struct = "structs",
	object = "objects",
	class = "classes",
	enum = "enums",
	type = "types",
	annotation = "annotations",
	category = "categories",
	fun = "functions",
	extension = "extensions",
	import = "imports",
	static = "statics"
}

function module_for_source(sir, source)
	for module, units in pairs(sir.modules) do
		for unit in all(units) do
			if unit.source == source then
				return module
			end
		end
	end
	
	return nil
end

-- The return type is (nil, nil) if the symbol is not found,
-- (qualified_name, nil) if the symbol is found, and
-- (nil, error) if the lookup was erroneous. The returned error is currently
-- always a table of `{ kind = "ambiguous", imports = { ... } }` where imports
-- are the imports containing the collision.
function lookup_symbol(sir, namespace, name, source, overload)
	assert(source)
	if (namespace == nil) return nil
	
	local function try_lookup(namespace, name)
		local qualified = path.concat(namespace, name)
		
		if sir.types[qualified] then
			return { group = "types", name = qualified }
		elseif sir.categories[qualified] then
			return { group = "categories", name = qualified }
		elseif sir.globals[qualified] then
			return { group = "globals", name = qualified }
		elseif sir.functions[qualified] then
			return { group = "functions", name = qualified }
		else
			local decl = sir.types[namespace] or sir.categories[namespace]
			if not decl and sir.functions[namespace] then
				decl = sir.functions[namespace][overload]
			end
			
			if decl and decl.generics then
				for generic in all(decl.generics) do
					if (generic.name == name) return { group = "generics", name = qualified }
				end
			end
			
			return nil
		end
	end
	
	-- Local case.
	-- Does not need to resolve visibility, siblings and ancestors are always visible.
	local result = try_lookup(namespace, name)
	if (result) return result
	
	-- If we have more ancestors we propagate the search.
	-- The prefix function returns nil if there is no prefix.
	local parent_namespace = path.prefix(namespace)
	if parent_namespace then
		local sym, err = lookup_symbol(sir, parent_namespace, name, source)
		if (err) return nil, err
		if (sym) return sym
	end
	
	-- Remote case.
	-- In this case we actually still don't fully resolve visibility.
	-- In the case of functions they can have overloads, and each overload can
	-- have different visibility, so if any overload is visible it counts as resolved.
	-- The actual decision is deferred until overload resolution, an invisible
	-- overload simply does not participate.
	local potential_imports = sir.imports[namespace]
	if (not potential_imports) return nil
	local imports = {}
	for import in all(potential_imports) do
		if (import.source == source) add(imports, import)
	end
	
	local candidate
	local ambiguous_imports = {}
	for import in all(imports) do
		local remote_namespace = import.path
		
		local new_candidate = try_lookup(remote_namespace, name)
		if (not new_candidate) goto continue
		
		local is_new_visible = false
		if new_candidate.group == "functions" then
			for overload in all(sir.functions[new_candidate.name]) do
				if overload.pub then is_new_visible = true break end
			end
		elseif new_candidate.group == "generics" then
			is_new_visible = true -- generics are always publicly visible.
		else
			is_new_visible = sir[new_candidate.group][new_candidate.name].pub
		end
		if (not is_new_visible) goto continue
		
		candidate = new_candidate
		add(ambiguous_imports, import)
		
		::continue::
	end
	
	-- Fail on ambiguity.
	if #ambiguous_imports > 1 then
		return nil, { kind = "ambiguous", imports = ambiguous_imports }
	end
	
	-- If we found a candidate then there is no ambiguity, otherwise we fail
	-- and the recursive chain propagates nil all the way up.
	if (candidate) return candidate
end

-- The most important stage of compilation, transforms a syntax tree into
-- an intermediate graph representation and performs various passes on said graph.
-- It evaluates the constant part of the language, so its types and compile time
-- code at the same time, including meta code taking advantage of reflection.
-- The resulting graph is ready to be lowered into any representation or have
-- extra backend specific passes run.
function sema(modules, autoimports, errors)
	local sir = {
		modules = modules,
		autoimports = autoimports,
		types = {},
		categories = {},
		functions = {},
		extensions = {},
		globals = {},
		imports = {},
		reachable = {},
		
		diagnostics = {},
		erroneous = false
	}
	
	for err in all(errors) do
		sir.erroneous = true
		if err.kind == "error" then
			add(sir.diagnostics, err)
		else
			error(err)
		end
	end
	
	-- Stripped down sir which can be serialized.
	function sir:serial()
		return {
			modules = self.modules,
			autoimports = autoimports,
			
			diagnostics = self.diagnostics,
			erroneous = self.erroneous
		}
	end
	
	function sir:parse_error(token, reason, help_text)
		self.erroneous = true
		
		add(self.diagnostics, {
			kind = "parse",
			reason = reason,
			token = token,
			help_text = help_text
		})
	end
	
	function sir:compile_error(span, reason, help_text)
		if (not span.is_span and span.span) span = span.span
		assert(span.is_span, "found: " .. pod(span))
		
		self.erroneous = true
		
		add(self.diagnostics, {
			kind = "error",
			reason = reason,
			span = span,
			help_text = help_text
		})
	end
	
	function sir:compile_warning(span, reason, help_text)
		if (not span.is_span and span.span) span = span.span
		assert(span.is_span, "found: " .. pod(span))
		
		add(self.diagnostics, {
			kind = "warning",
			reason = reason,
			span = span,
			help_text = help_text
		})
	end
	
	function sir:compile_info(span, reason, help_text)
		if (not span.is_span and span.span) span = span.span
		assert(span.is_span, "found: " .. pod(span))
		
		add(self.diagnostics, {
			kind = "info",
			reason = reason,
			span = span,
			help_text = help_text
		})
	end
	
	local exts = {}
	-- body extracted to walk recursively
	local function collect_decl(decl, source, namespace, parent, toplevel)
		if (toplevel == nil) toplevel = false
		
		if
			decl.kind == "struct" or
			decl.kind == "object" or
			decl.kind == "class" or
			decl.kind == "enum" or
			decl.kind == "type" or
			decl.kind == "annotation"
		then
			if decl.kind == "annotation" and not toplevel then
				sir:compile_error(decl,
					"nested annotation",
					"Annotations are only allowed at unit level."
				)
			end
			
			local qualified_name = path.concat(namespace, decl.name)
			if sir.types[qualified_name] then
				sir:compile_error(decl, "duplicate type")
				sir:compile_error(sir.types[qualified_name].ast, "duplicate type")
			end
			
			sir.types[qualified_name] = {
				kind = decl.kind,
				ast = decl,
				namespace = namespace,
				source = source,
				parent = parent
			}
			
			-- This inherently excludes type aliases since the iterator will fail.
			for subdecl in all(decl.decls) do
				collect_decl(subdecl, source, qualified_name, qualified_name)
			end
		elseif decl.kind == "category" then
			if not toplevel then
				sir:compile_error(decl,
					"nested category",
					"Categories are only allowed at unit level."
				)
			end
			
			local qualified_name = path.concat(namespace, decl.name)
			
			if sir.categories[qualified_name] then
				sir:compile_error(decl, "duplicate category")
				sir:compile_error(sir.categories[qualified_name].ast, "duplicate category")
			end
			
			sir.categories[qualified_name] = {
				ast = decl,
				namespace = namespace,
				source = source
			}
		elseif decl.kind == "extension" then
			if not toplevel then
				sir:compile_error(decl,
					"nested extension",
					"Extensions are only allowed at unit level."
				)
			end
			local qualified_name = path.concat(namespace, decl.name)
			-- Note that extensions are namespaced to their origin module,
			-- but the declaration they extend may be in another.
			-- This needs to be resolved later once imports are figured out.
			-- This is too early to resolve subdecls as well.
			add(exts, {
				ast = decl,
				namespace = namespace,
				qualified_name = qualified_name,
				source = source
			})
			
			-- We do actually want to resolve subdecls already.
			-- They belong to the extension namespace and not
			-- the actual type being extended, and their
			-- visibility is conditional on the extension being in scope.
			-- This produces somewhat esoteric paths.
			for subdecl in all(decl.decls) do
				collect_decl(subdecl, source, qualified_name, qualified_name)
			end
		elseif decl.kind == "member" then
			-- We only care about global members.
			-- Type members, even const/static are resolved within types
			-- because they need to inherit their generic context and preserve ordering.
			if toplevel then
				local qualified_name = path.concat(namespace, decl.name)
				if sir.globals[qualified_name] then
					sir:compile_error(decl, "duplicate global")
					sir:compile_error(sir.globals[qualified_name].ast, "duplicate global")
				end
				
				if not (decl.static or decl.const) then
					sir:compile_error(decl,
						"global instance member",
						"Global variables always need to be qualified as either `const` or `static`."
					)
				end
				
				sir.globals[qualified_name] = {
					ast = decl,
					namespace = namespace,
					source = source
				}
			end
		elseif decl.kind == "fun" then
			local qualified_name = path.concat(namespace, decl.name)
			if not sir.functions[qualified_name] then
				sir.functions[qualified_name] = {}
			end
			
			add(sir.functions[qualified_name], {
				ast = decl,
				namespace = namespace,
				source = source,
				name = decl.name
			})
		elseif decl.kind == "init" then
			local qualified_name = path.concat(namespace, "init")
			if not sir.functions[qualified_name] then
				sir.functions[qualified_name] = {}
			end
			
			add(sir.functions[qualified_name], {
				ast = decl,
				namespace = namespace,
				source = source,
				name = "init"
			})
		elseif decl.kind == "import" then
			local qualified_name = namespace
			if not sir.imports[qualified_name] then
				sir.imports[qualified_name] = {}
			end
			
			for import in all(sir.imports[qualified_name]) do
				if import.path == decl.path then
					sir:compile_error(decl,
						"duplicate import",
						"Importing the same module more than once is not allowed."
					)
				end
			end
			
			add(sir.imports[qualified_name], {
				ast = decl,
				path = decl.path,
				source = source
			})
		else
			sir:compile_error(decl, "unimplemented decl: " .. decl.kind)
		end
	end
	
	for module, units in pairs(sir.modules) do
		for unit in all(units) do
			for decl in all(unit.decls) do
				collect_decl(decl, unit.source, module, nil, true)
			end
		end
	end
	
	local all_modifiers = {
		"pub", "unsafe", "open", "override", "inherent",
		"const", "static", "inline", "implicit", "base"
	}
	local category_modifiers = {
		pub = true, unsafe = true, inherent = true
	}
	local struct_modifiers = {
		pub = true, const = true
	}
	local enum_modifiers = {
		pub = true, const = true
	}
	local class_modifiers = {
		pub = true, open = true, const = true, base = true
	}
	local object_modifiers = {
		pub = true, open = true, const = true
	}
	local annotation_modifiers = {
		pub = true, unsafe = true
	}
	local type_modifiers = {
		pub = true
	}
	local fun_modifiers = {
		pub = true, override = true, unsafe = true, const = true,
		open = true, implicit = true, inline = true
	}
	local global_modifiers = {
		pub = true, const = true, static = true
	}
	local import_modifiers = {}
	local extension_modifiers = {}
	
	local function resolve_modifiers(decl, allowed)
		for modifier in all(all_modifiers) do
			if not allowed[modifier] and decl.ast[modifier] then
				sir:compile_error(decl.ast,
					"modifier `" .. modifier .. "` is not allowed on " .. plural[decl.ast.kind]
				)
			else
				decl[modifier] = decl.ast[modifier]
			end
		end
	end
	
	-- Resolve declaration modifiers.
	do
		for _, imports in pairs(sir.imports) do
			for import in all(imports) do
				resolve_modifiers(import, import_modifiers)
			end
		end
		
		for _, global in all(sir.globals) do
			resolve_modifiers(global, global_modifiers)
			if global.const and global.static then
				sir:compile_error(ty.ast,
					"incompatible modifiers",
					"A global member can't be both `const` and `static`."
				)
			end
		end
		
		for _, category in pairs(sir.categories) do
			resolve_modifiers(category, category_modifiers)
		end
		
		for ext in all(exts) do
			resolve_modifiers(ext, extension_modifiers)
		end
		
		for _, ty in pairs(sir.types) do
			if ty.kind == "struct" then
				resolve_modifiers(ty, struct_modifiers)
			elseif ty.kind == "enum" then
				resolve_modifiers(ty, enum_modifiers)
			elseif ty.kind == "class" then
				resolve_modifiers(ty, class_modifiers)
				
				if ty.open and ty.base then
					sir:compile_error(ty.ast,
						"incompatible modifiers",
						"A base class is inherently open as it is useless by itself."
					)
				end
			elseif ty.kind == "object" then
				resolve_modifiers(ty, object_modifiers)
			elseif ty.kind == "annotation" then
				resolve_modifiers(ty, annotation_modifiers)
			elseif ty.kind == "type" then
				resolve_modifiers(ty, type_modifiers)
			else
				error "unhandled case"
			end
		end
		
		for _, overloads in pairs(sir.functions) do
			for overload in all(overloads) do
				resolve_modifiers(overload, fun_modifiers)
				
				if overload.const and overload.inline then
					sir:compile_error(overload.ast,
						"incompatible modifiers",
						"Inlining is meaningless for a compile time only function."
					)
				end
				
				if overload.implicit and overload.name ~= "init" then
					sir:compile_error(overload.ast,
						"incompatible modifiers",
						"Only initializers can be implicit."
					)
				end
			end
		end
	end
	
	-- Resolve auto-imports.
	for module, units in pairs(sir.modules) do
		for unit in all(units) do
			for autoimport in all(sir.autoimports) do
				if (path.nested_in(module, autoimport)) goto skip
				
				if not sir.imports[module] then
					sir.imports[module] = {}
				end
				
				local decl = parse_import(
					tokenize("import " .. autoimport, nilspan(unit.source))
				)
				
				add(sir.imports[module], {
					ast = decl,
					path = decl.path,
					source = unit.source
				})
				::skip::
			end
		end
	end
	
	local function is_valid_import(path)
		return sir.modules[path] ~= nil
	end
	
	for module, imports in pairs(sir.imports) do
		for import in all(imports) do
			if path.nested_in(module, import.path) then
				sir:compile_error(import.ast,
					"recursive import",
					"Importing implicitly visible modules is not allowed."
				)
			end
			if not is_valid_import(import.path) then
				sir:compile_error(import.ast,
					"unresolved import",
					"Is this module in the search path?"
				)
			end
		end
	end
	
	-- Identify duplicates.
	-- Duplicates are already resolved within the same lookup group,
	-- but they can still exist between them.
	for qualified_name, category in pairs(sir.categories) do
		if sir.types[qualified_name] then
			sir:compile_error(category.ast, "duplicate declaration")
			sir:compile_error(sir.types[qualified_name].ast, "duplicate declaration")
		end
	end
	
	-- todo: replace with the evaluator.
	--[[
	local function resolve_type_expr(expr, namespace, source, overload)
		assert(source)
		if (not expr) return nil
		
		if expr.kind == "ident" then
			local sym, err
			if expr.name == "Self" then
				sym = "Self"
			else
				sym, err = lookup_symbol(sir, namespace, expr.name, source, overload)
			end
			
			if err then
				assert(err.kind == "ambiguous") -- in case more errors get added?
				
				local names = {}
				for import in all(err.imports) do add(names, "`" .. import.path .. "`") end
				sir:compile_error(expr,
					"ambiguous type",
					"The type is visible through multiple imports:\n- "
						.. table.concat(names, "\n- ")
				)
				for import in all(err.imports) do
					sir:compile_info(import.ast,
						"ambiguity raised here",
						"This import introduces ambiguity for lookup of `" .. expr.name .. "`."
					)
				end
			elseif not sym then
				sir:compile_error(expr,
					"unresolved type",
					"Could not find type '" .. expr.name .. "' in this scope."
				)
			else
				return { tag = "TypeRef", name = expr.name, symbol = sym }
			end
		elseif expr.kind == "generics" then
			local base = resolve_type_expr(expr.callee, namespace, source, overload)
			
			local params = {}
			for param in all(expr.params) do
				-- todo: needs eval to allow value generic expressions
				add(params, {
					label = param.label,
					value = resolve_type_expr(param.value, namespace, source, overload)
				})
			end
			
			return { tag = "GenericInst", base = base, params = params }
		elseif expr.kind == "tuple" then
			local elements = {}
			for element in all(expr.elements) do
				add(elements, {
					label = element.label,
					type = resolve_type_expr(element.value, namespace, source, overload)
				})
			end
			
			return { tag = "Tuple", elements = elements }
		elseif expr.kind == "intrinsic" then
			return { tag = "Intrinsic", name = expr.name }
		else
			-- todo: where does eval go?
			sir:compile_error(expr,
				"invalid type expression",
				"Expected a type but got `" .. expr.kind .. "`."
			)
			return { tag = "Erroneous" }
		end
	end
	]]--
	
	-- Resolve generic scopes.
	-- Associates declarations with their parameters.
	local function resolve_decl_generics(qualified_name, decl)
		local generics = {}
		
		for generic in all(decl.ast.generics) do
			add(generics, {
				raw = generic,
				kind = generic.kind,
				label = generic.label,
				name = generic.name
			})
		end
		
		decl.generics = generics
	end
	for qualified_name, ty in pairs(sir.types) do
		resolve_decl_generics(qualified_name, ty)
	end
	for qualified_name, category in pairs(sir.categories) do
		resolve_decl_generics(qualified_name, category)
	end
	for qualified_name, overloads in pairs(sir.functions) do
		for overload in all(overloads) do
			resolve_decl_generics(qualified_name, overload)
		end
	end
	
	-- Resolve expressions within generic lists.
	local function resolve_decl_generic_exprs(qualified_name, decl, overload)
		for generic in all(decl.generics) do
			if generic.kind == "type" then
				if generic.raw.default then
					generic.default = 
						evaluator(sir, qualified_name, decl.source, "type", overload)
							:eval(generic.raw.default)
				end
			elseif generic.kind == "value" then
				generic.type =
					evaluator(sir, qualified_name, decl.source, "type", overload)
						:eval(generic.raw.type)
				-- todo: resolve the default value-expression.
			else
				error("unknown generic kind: " .. tostr(generic.kind))
			end
		end
	end
	for qualified_name, ty in pairs(sir.types) do
		resolve_decl_generic_exprs(qualified_name, ty)
	end
	for qualified_name, category in pairs(sir.categories) do
		resolve_decl_generic_exprs(qualified_name, category)
	end
	for qualified_name, overloads in pairs(sir.functions) do
		for i, overload in ipairs(overloads) do
			resolve_decl_generic_exprs(qualified_name, overload, i)
		end
	end
	
	-- Resolve type shape.
	-- Verify the structure of all types.
	for qualified_name, ty in pairs(sir.types) do
		if ty.kind == "struct" or ty.kind == "class" or ty.kind == "object" then
			ty.members = {}
			ty.lifetimebound = false
			ty.superlist = {}
			
			for super in all(ty.ast.superlist) do
				add(ty.superlist, evaluator(sir, ty.namespace, ty.source, "type"):eval(super))
			end
			
			for decl in all(ty.ast.decls) do
				if decl.kind == "member" then
					-- We need to easily tell in the future if a type requires
					-- lifetime analysis.
					-- Type members do not bind instance lifetimes.
					if not (decl.static or decl.const) and decl.ref then
						ty.lifetimebound = true
					end
					
					add(ty.members, {
						pub = decl.pub,
						mut = decl.mut,
						ref = decl.ref,
						name = decl.name,
						type = evaluator(sir, qualified_name, ty.source, "type"):eval(decl.type)
					})
				end
			end
		elseif ty.kind == "enum" then
			ty.cases = {}
			-- Enums do not need a tag type to support implicitly tagged
			-- enums in esoteric platform context where a weird representation for tags
			-- is desirable, though that does not seem very likely.
			-- The first element of the superlist, if not a category, is the
			-- raw tag type for the enum.
			ty.superlist = {}
			
			for super in all(ty.ast.superlist) do
				add(typ.superlist, evaluator(sir, ty.namespace, ty.source, "type"):eval(super))
			end
			
			for case in all(ty.ast.cases) do
				local case_def = { name = case.name }
				
				if case.tuple then
					case_def.payload = evaluator(sir, qualified_name, ty.source, "type"):eval(case.tuple)
				elseif case.raw then
					-- Eval is needed for raw case values.
					case_def.raw = evaluator(sir, qualified_name, ty.source, "value"):eval(case.raw)
				end
				add(ty.cases, case_def)
			end
		elseif ty.kind == "type" then
			ty.value = evaluator(sir, qualified_name, ty.source, "type"):eval(ty.ast.value)
		end
	end
	
	-- Resolve signatures.
	-- Verify all the types used in signatures.
	for qualified_name, overloads in pairs(sir.functions) do
		for i, overload in ipairs(overloads) do
			overload.args = {}
			overload.throws = {}
			
			for arg in all(overload.ast.args) do
				add(overload.args, {
					label = arg.label,
					name = arg.name,
					mut = arg.mut,
					ref = arg.ref,
					lazy = arg.lazy,
					type = evaluator(sir, qualified_name, overload.source, "type", i)
						:eval(arg.type),
					default = nil -- todo
				})
			end
			
			for throw in all(overload.ast.throws) do
				add(overload.throws,
					evaluator(sir, qualified_name, overload.source, "type", i):eval(throw)
				)
			end
			
			if overload.ast.returns then
				overload.returns =
					evaluator(sir, qualified_name, overload.source, "type", i)
						:eval(overload.ast.returns)
			else
				-- todo: default to the empty tuple.
			end
		end
	end
	
	-- We now resolved fully qualified declarations, but extensions
	-- were unable to be resolved yet. They need to be qualified
	-- to the corresponding types and store their namespace rather
	-- than be qualified by the namespace module, which is
	-- possible now that we can actually traverse imports.
	for ext in all(exts) do
		-- todo: structural extend.
		-- todo: unify with types.
		-- todo: attach to types.
		ext.target = evaluator(sir, ext.namespace, ext.source, "type")
			:eval(ext.ast.target)
		
		--[[
		if ext.target_name == "Any" then -- blanket case
			ext.target = "Any"
		elseif
			sir.types[ext.qualified_name] or
			sir.categories[ext.qualified_name]
		then -- local case
			ext.target = ext.qualified_name
		else -- remote case
			for import in all(sir.imports[ext.namespace]) do
				if import.source == ext.source then
					local attempt = path.concat(import.path, ext.target_name)
					local query = sir.types[attempt] or sir.categories[attempt]
					if query and query.pub then
						ext.target = attempt
						goto resolve
					end
				end
			end
			
			sir:compile_error(ext.ast,
				"unresolved extension target `" .. ext.qualified_name .. "`",
				"Did you mean to import it?"
			)
			goto continue
		end
		
		::resolve::
		if not sir.extensions[ext.target] then
			sir.extensions[ext.target] = {}
		end
		add(sir.extensions[ext.target], ext)
		::continue::
		]]--
	end
	
	-- Verify overload uniqueness.
	-- This is a partial check, it would be unrealistic to compare
	-- every possible combination for ambiguity, nor does it make sense anyway.
	-- It could for instance only be ambiguous when both overloads are actually
	-- in scope, and it is possible to disambiguate manually, even if painful.
	-- Considering this, the best solution is to compare only type ambiguity and
	-- allow ambiguous defaults, and only making ambiguous usage an error, as
	-- that could cause ambiguity for lowering.
	--
	-- It is important that inline categories are desugared by this stage as it
	-- depends on understanding the generic structure. We do not want
	-- to deal with different but equivalent forms.
	local function verify_signature_uniqueness(lhs, rhs)
		-- Obviously, if the argument lists are of different count they are different.
		if (#lhs.args ~= #rhs.args) return
		-- Similarly, different generics are always okay.
		if (#lhs.generics ~= #rhs.generics) return
		-- Const always overloads a function, it always takes priority
		-- in order to provide features like transparent compile-time memory allocation.
		if (lhs.const ~= rhs.const) return
		-- Lastly, we can make a similar distinction for constraints.
		if (#lhs.where.constrs ~= #rhs.where.constrs) return
		-- Where lists can also contain expressions, but those are for
		-- specifying compile time contracts. As they do not disambiguate signatures
		-- in a way reasonable to solve, we just ignore them here.
		
		for i = 1, #lhs.args do
			local la, ra = lhs.args[i], rhs.args[i]
			
			-- If the labels are different the signature can be disambiguated.
			if (la.label ~= ra.label) return
			
			-- If one variant is a mutable projection it requires the caller to
			-- use the `&` sigil, which disambiguates the usage.
			-- Not so for a borrow of course, since it is purely a semantic feature.
			if (la.ref ~= ra.ref) return
			if (la.ref and ra.ref and la.mut ~= ra.mut) return
			
			-- If the types are different then it's definitely not ambiguous.
			-- todo: missing API
		end
		
		-- If we fall through to here, we will try to disambiguate using generics.
		-- We can ignore generic labels, because they don't exist for overloading,
		-- but rather skipping parameters for inference, or support for
		-- multiple parameter packs.
		
		-- Finally, if we still find the signatures ambiguous, we can only look at
		-- category constraints
		
		-- todo: for now we can't fully implement this so we will silence the
		-- errors until we can.
		
		-- If we made it here the signatures are unambiguously ambiguous.
		-- That kind of case would also mangle the same way which is of course really bad.
		-- We can error on the left side, the symmetric invocation will fail the right.
		--sir:compile_error(lhs.ast,
		--	"duplicate overload",
		--	"Overloads are not allowed to be unconditionally ambiguous."
		--)
	end
	for _, overloads in pairs(sir.functions) do
		if #overloads ~= 1 then
			for lhs in all(overloads) do
				for rhs in all(overloads) do
					--if (lhs ~= rhs) verify_signature_uniqueness(lhs, rhs)
				end
			end
		end
	end
	
	-- Check signatures.
	-- Verify that all function signatures are correct.
	
	-- Resolve bodies.
	-- Verify that function bodies have correct types and lifetimes
	-- across all of their expressions.
	for qualified_name, overloads in pairs(sir.functions) do
		for overload in all(overloads) do
			
		end
	end
	
	-- Consteval.
	-- Eagerly try evaluate any and all code.
	
	-- Identify bad naming.
	-- Linting has to happen late in evaluation because it can consider
	-- annotations, which implies interacting with fully const-evaluated sir.
	
	-- Cost analyze.
	-- Recursively compute the cost of functions by summing together
	-- the cost of expressions. Recursive functions are excluded as
	-- cost analysis would be impossible and irrelevant considering
	-- they can't be inlined anyway.
	
	-- Inline.
	-- Inline low cost code. Aggression should be controllable by the frontend.
	
	-- Optimize.
	-- Apply optmization passes when optimization enabled.
	
	-- Mark reachable.
	-- Figure out what code is reachable and collect it so that
	-- backends only lower the minimum required API, crucial to avoid
	-- depending on unused external symbols especially.
	
	return sir
end

-- Compiler ---------------------------------------------------------------------------

-- This is the final stage of compilation, emits the output (in this case Lua code)
-- from the intermediate representation.
function emit(sir)
	local out = {}
	
	for reachable in all(sir.reachable) do
		add(out, emit_fun(sir, sir.functions[reachable]))
	end
	
	if sir.entry then
		-- todo: emit entry.
	end
	
	return table.concat(out, "\n")
end

function emit_fun(sir, fun)
	
end

-- OLD NOTES: todo(update)
-- On Strawberry ABI for the Lua backend;
-- The ABI is currently very simple. All type layout is destructured into
-- underlying primitive members, nesting accounted for. Each primitive element,
-- no matter the type, takes up exactly one Lua value.
-- The Strawberry Pointer<to: T> type lowers to an array based Lua table.
-- The picotron library provides table support through the dynamic
-- dictionary/array/value LuaObject type, which describes an arbitrary Lua value that
-- can be used completely transparently, allowing for dynamic typing.
-- Projections lower to a functional update unless their lifetime is bound
-- and functions/closures are interoperable between the languages.
--
-- On the Lua ABI;
-- Calling extern functions with the Lua calling convention requires declaring all
-- arguments as the LuaObject type. For ease of interoperability the picotron
-- module provides implicit conversions bridging 1 sized primitive values through an
-- unsafe transmute, because it is sound in the context of the Lua platform.
-- Recovering back to Strawberry types requires explicit, failable conversion.

function unique_type_id(typ)
	error "todo"
end

function unique_const_val_id(val)
	error "todo"
end

-- A name mangling derived from C++ Itanium but adapted to Strawberry specifics.
-- Mangling happens based on the qualified name, argument labels and the
-- corresponding type id (handling tuples and packs) as well as value generics,
-- since we need to disambiguate them. Finally, because exceptions are
-- monomorphised, we need to specify which exceptions this instantiation
-- is forwarding rather than panicking (monomorphised based on catch expression).
-- Unhandled exceptions monomorphise a function which panics rather than forwarding
-- any errors, so it mangles the same as if not having any exceptions at all,
-- also allowing the addition of exceptions to be a non-abi-breaking change.
-- Constraints are required to be in canonical sorted order.
function mangle(qualified_name, args, generics, excepts, constrs, ret)
	local buf = "_str_"
	
	for component in split(qualified_name, ".") do
		buf ..= tostr(#component) .. component
	end
	
	buf ..= "g" .. tostr(#generics) .. "g"
	
	for i, generic in ipairs(generics) do
		if generic.kind == "value" then
			local val_id = unique_const_val_id(generic.value)
			local typ_id = unique_type_id(generic.type)
			buf ..= "v" .. tostr(#typ_id) .. typ_id .. tostr(#val_id) .. val_id
		elseif generic.kind == "type" then
			buf ..= "t" .. tostr(i)
		elseif generic.kind == "value_pack" then
			error "not in 0.1.0"
			buf ..= "vp"
		elseif generic.kind == "type_pack" then
			error "not in 0.1.0"
			buf ..= "tp"
		else
			error "unhandled generic kind"
		end
	end
	
	buf ..= "a" .. tostr(#args) .. "a"
	
	for arg in all(args) do
		local id = unique_type_id(arg.type)
		buf ..= tostr(#arg.label) .. arg.label .. tostr(#id) .. id
	end
	
	buf ..= "e" .. tostr(#excepts) .. "e"
	
	for except in all(excepts) do
		local id = unique_type_id(except.type)
		buf ..= tostr(#id) .. id
	end
	
	buf ..= "c" .. tostr(#constrs) .. "c"
	
	for constr in all(constrs) do
		if constr.kind == "conformance" then
			local id = unique_type_id(constr.category)
			
			local idx
			for i, generic in ipairs(generics) do
				if generic.kind == "type" and generic.name == constr.name then
					idx = i
				end
			end
			if (not idx) error "invalid signature"
			
			buf ..= "C" .. tostr(idx) .. "_" .. tostr(#id) .. id
		else
			error "unhandled constraint kind"
		end
	end
	
	do
		local id = unique_type_id(ret.type)
		buf ..= "r" .. tostr(#id) .. id
	end
	
	return buf
end

function demangle(symbol)
	local qualified_name
	local args = {}
	local generics = {}
	local excepts = {}
	local constrs = {}
	local ret
	
	error "todo"
	
	return {
		qualified_name = qualified_name,
		args = args,
		generics = generics,
		excepts = excepts,
		constrs = constrs,
		ret = ret
	}
end

-- Frontend ---------------------------------------------------------------------------

function main()
	local args = env().argv
	
	local command = args[1]
	
	if command and command == "init" then
		print("not implemented")
	elseif command and command == "check" then
		print("not implemented")
	elseif command and command == "build" then
		strc()
	elseif command and command == "run" then
		strc(nil, nil, true)
	elseif command and command == "test" then
		print("not implemented")
	elseif command and command == "clean" then
		clean_filesystem_state()
	elseif command and command == "cserve" then
		strc_serve(tonum(args[2]))
	elseif command and command == "ckill" then
		strc_kill_servers()
	elseif command and command == "ctest" then
		strc_test()
	elseif command and command == "help" and help_text[args[2]] then
		print(help_text[args[2]])
	else
		print("\feWelcome to Strawberry!")
		print([[

usage: strc [subcommand] [options]

subcommands:
    -- project --
  init         Initialize a new Strawberry project in /ram/cart
  new          Initialize a new cart and Strawberry project in /ram/cart
  clean        Clean all the build caches.
  export       Export /ram/cart while automatically ignoring caches
  
    -- building --
  check        Analyze the project without building it
  build        Build the Strawberry project in /ram/cart
  run          Build and run the Strawberry project in /ram/cart
  test         Run unit tests of the Strawberry project in /ram/cart
  
    -- tidy --
  lint         Analyze the project with more pedantic diagnostics
  sisyphus     Convert tabs to spaces
  
    -- internal --
  cserve       Run as a language server for the code editor
  ckill        Kill the language server if running
  ctest        Run unit tests of the Strawberry compiler itself
  
  use `strc help [subcommand]` for detailed help information
]])
	end
end

help_text = {
	["init"] =
[[
usage: strc init [options]

The init subcommand prepares a cart for use with the Strawberry compiler.

options:
  -t [template-name]          Specify a template to initialize with.
                              By default it is always going to be `hello`.
                              Templates are found in
                              /appdata/shared/strawberry/templates
]],
	["sisyphus"] =
[[
usage: strc sisyphus [options]

Converts tabs to spaces, useful when they accidentally end up
in source files and are preventing compilation.

options:
  -f [file-name]              Rather than converting all Strawberry files
                              visible to the compiler run sisyphus on
                              an arbitrary file, even of a different type.
]]
}

function ensure_filesystem_state()
	if not fstat("/appdata/shared/strawberry/cache") then
		cp(
			"/appdata/shared/strawberry/templates/cache",
			"/ram/cart/cache"
		)
	end
end

function clean_filesystem_state()
	rm("/ram/cart/cache")
end

__STRC_STD_DEV_MODE = true

-- This is the compiler frontend, also invoked with arguments when using
-- strc as a command line utility. It requires a path to the output file
-- as well as module search paths, with the standard library and ram cart
-- directories already being added by default.
function strc(fileout, module_paths, run)
	if (type(fileout) == "boolean" and fileout) fileout = "/ram/cart/main.lua"
	module_paths = module_paths or {}
	if (run == nil) run = false
	
	if __STRC_STD_DEV_MODE then
		add(module_paths, { path = "/ram/cart/std", recursive = true })
	else
		add(module_paths, { path = "/appdata/shared/strawberry/std", recursive = true })
	end
	add(module_paths, { path = "/appdata/shared/strawberry/lib", recursive = true })
	add(module_paths, { path = "/ram/cart/src", recursive = true })
	
	local autoimports = {
		"core"
	}
	
	ensure_filesystem_state()
	
	local files = collect_all_sources(module_paths)
	local modules, errors = parse_modules(files)
	local sir = sema(modules, autoimports, errors)
	local output = emit(sir)
	
	if sir then
		for diagnostic in all(sir.diagnostics) do
			print_compile_diagnostic(diagnostic)
		end
	end
	
	if fileout then
		--local iconsrc = fetch_metadata("/appdata/shared/strawberry/templates/exec.lua")
		--store(fileout, output, { icon = iconsrc.icon })
	end
	
	if run then
		create_process("/system/apps/terminal.lua", {
			corun_program = fileout,
			window_attribs = {
				pwc_output = true,
				show_in_workspace = true
			}
		})
	end
	
	return sir
end

function collect_all_sources(module_paths)
	local files = {}
	
	for path in all(module_paths) do
		local found = collect_module_files(path.path, path.recursive)
		
		for file in all(found) do
			add(files, file)
		end
	end
	
	return files
end

function collect_module_files(path, recursive, out)
	out = out or {}
	
	for entry in all(ls(path)) do
		local full = path .. "/" .. entry
		local kind = fstat(full)
		
		if kind == "file" then
			if string.sub(entry, -4) == ".str" then
				add(out, full)
			end
		elseif kind == "folder" and recursive then
			collect_module_files(full, true, out)
		end
	end
	
	return out
end

function parse_modules(paths)
	local modules = {}
	local errors = {}
	
	for path in all(paths) do
		local function try()
			local cache_path = "/ram/cart/cache/ast" .. fullpath(path)
			local cache_meta = fetch_metadata(cache_path)
			local meta = fetch_metadata(path)
			
			local ast
			if cache_meta and cache_meta.modified > meta.modified then
				ast = fetch(cache_path)
			else
				local src = fetch(path)
				
				if #src == 0 then
					error("empty source file: " .. path)
				end
				
				ast = parse(tokenize(src, path))
				store(cache_path, ast)
			end
			
			if ast then
				local modname = tostring(ast.name)
				
				if not modules[modname] then
					modules[modname] = {}
				end
				
				add(modules[modname], ast)
			end
		end
		
		local ok, err = pcall(try)
		
		if not ok then
			add(errors, err)
		end
	end
	
	return modules, errors
end

function print_compile_diagnostic(err)
	--fetch("/system/fonts/lil_mono.font"):poke(0x5600)
	
	local cl
	if err.kind == "error" then
		cl = "\f8"
	elseif err.kind == "warning" then
		cl = "\fa"
	elseif err.kind == "info" then
		cl = "\fc"
	else
		error "unknown diagnostic"
	end
	
	local f, l = err.span.first, err.span.last
	print(cl .. err.kind .. ":\f7 " .. err.reason)
	print(string.format(
		--"\f6%s\f7:\f9%d\f7:\f9%d\f7-\f9%d\f7:\f9%d",
		"\f6%s\f7:%d:%d-%d:%d",
		f.source, f.line, f.column - f.count + 1, l.line, l.column
	))
	
	local max_lines = 3
	local line_count = l.line - f.line + 1
	
	local src = fetch(f.source)
	assert(src)
	
	local lines = {}
	
	local line_n = 1
	for ln in src:gmatch("[^\n]*") do
		if (line_n >= f.line) add(lines, ln)
		if (line_n >= l.line) break
		if (#lines >= max_lines) break
		line_n += 1
	end
	
	for idx, ln in ipairs(lines) do
		local line_n = f.line + idx - 1
		
		local fmt = tostring(line_n)
		fmt = string.rep(" ", 4 - #fmt) .. fmt .. " | \015"
		
		print("\014\f6" .. fmt .. "\f7" .. ln)
		if f.line == l.line then
			local start_col = f.column - f.count
			local width = l.column - start_col
			
			print("\014\f6     | \015" .. cl ..
				string.rep(" ", start_col) ..
				string.rep("^", max(1, width))
			)
		elseif line_n == f.line then
			print("\014\f6     | \015" .. cl ..
				string.rep(" ", f.column - f.count) ..
				string.rep("^", #ln - (f.column - f.count))
			)
		elseif line_n == l.line then
			print("\014\f6     | \015" .. cl .. string.rep("^", l.column))
		else
			print("\014\f6     | \015" .. cl .. string.rep("^", #ln))
		end
	end
	
	if line_count > max_lines then
		print("\014\f6 ... | \015")
	end
	
	if err.help_text then
		print("\f6" .. err.help_text)
	end
	
	print("")
end

-- Server -----------------------------------------------------------------------------

-- Starts a language server for the code editor.
function strc_serve(parent_id)
	local clients = { parent_id }
	
	on_event("register_client", function(msg)
		add(clients, msg.client_id)
	end)
	
	on_event("get_diagnostics", function(msg)
		local sir
		local function try() sir = strc() end pcall(try)
		if (sir) return { diags = sir.diagnostics, sir = sir:serial() }
	end)
	
	on_event("try_run", function(msg)
		local sir
		local function try() sir = strc(true, nil, true) end pcall(try)
	end)
	
	_update = function() end
end

function strc_kill_servers()
	local processes = fetch("/ram/system/processes.pod")
	local id = pid()
	
	for process in all(processes) do
		if process.id ~= id and process.name == "strc" then
			send_message(2, { event = "kill_process", proc_id = process.id })
			print("killed " .. tostring(process.id))
		end
	end
end

-- Tests ------------------------------------------------------------------------------

function strc_test()
	local expr_tests = {
		{
			feat = "identifier",
			expr = "value",
			expect = "value"
		},
		{
			feat = "intrinsic",
			expr = "#value",
			expect = "#value"
		},
		{
			feat = "true",
			expr = "true",
			expect = "true"
		},
		{
			feat = "false",
			expr = "false",
			expect = "false"
		},
		{
			feat = "integer",
			expr = "1",
			expect = "1"
		},
		{
			feat = "decimal",
			expr = "1.1",
			expect = "1.1"
		},
		{
			feat = "hexadecimal",
			expr = "0xAB",
			expect = "0xAB"
		},
		{
			feat = "binary",
			expr = "0b0101",
			expect = "0b0101"
		},
		{
			feat = "separated",
			expr = "10_000_000",
			expect = "10_000_000"
		},
		{
			feat = "string",
			expr = "\"Hello, world!\"",
			expect = "\"Hello, world!\""
		},
		{
			feat = "discard",
			expr = "_ = foo() + 1",
			expect = "(= _ (+ foo() 1))"
		},
		{
			feat = "block",
			expr = "{}",
			expect = "{  }"
		},
		{
			feat = "list",
			expr = "[]",
			expect = "[  ]"
		},
		{
			feat = "list with one value",
			expr = "[1]",
			expect = "[ 1 ]"
		},
		{
			feat = "list with many values",
			expr = "[1, 2, 3]",
			expect = "[ 1, 2, 3 ]"
		},
		{
			feat = "range to",
			expr = "1...2",
			expect = "(... 1 2)"
		},
		{
			feat = "range until",
			expr = "1..<2",
			expect = "(..< 1 2)"
		},
		{
			feat = "precedence",
			expr = "1 + 1 * 2",
			expect = "(+ 1 (* 1 2))"
		},
		{
			feat = "grouping",
			expr = "(1 + 1) * 2",
			expect = "(* (+ 1 1) 2)"
		},
		{
			feat = "tuple",
			expr = "(1, 1)",
			expect = "(1, 1)"
		},
		{
			feat = "labeled tuple",
			expr = "(x: 1, y: 1)",
			expect = "(x:1, y:1)"
		},
		{
			feat = "empty call",
			expr = "foo()",
			expect = "foo()"
		},
		{
			feat = "call",
			expr = "Point(1, 1)",
			expect = "Point(1, 1)"
		},
		{
			feat = "labeled call",
			expr = "Point(x: 1, y: 1)",
			expect = "Point(x:1, y:1)"
		},
		{
			feat = "method",
			expr = "object.nested.solid_at(1, 1)",
			expect = "object.nested.solid_at(1, 1)"
		},
		{
			feat = "labeled method",
			expr = "object.nested.solid_at(x: 1, y: 1)",
			expect = "object.nested.solid_at(x:1, y:1)"
		},
		{
			feat = "subscript",
			expr = "chunk[1, 1]",
			expect = "chunk[1, 1]"
		},
		{
			feat = "labeled subscript",
			expr = "chunk[x: 1, y: 1]",
			expect = "chunk[x:1, y:1]"
		},
		{
			feat = "generic",
			expr = "List<Int>(count: 5, repeating: 0)",
			expect = "List<Int>(count:5, repeating:0)"
		},
		{
			feat = "labeled generic",
			expr = "List<of: Int>(count: 5, repeating: 0)",
			expect = "List<of:Int>(count:5, repeating:0)"
		},
		{
			feat = "unsafe",
			expr = "print(unsafe unsafe_stuff())",
			expect = "print((unsafe unsafe_stuff()))"
		},
		{
			feat = "if",
			expr = "if cond { foo() }",
			expect = "(if cond then { foo() })"
		},
		{
			feat = "clean if",
			expr = "if cond then foo()",
			expect = "(if cond then foo())"
		},
		{
			feat = "if else",
			expr = "if cond { foo() } else { bar() }",
			expect = "(if cond then { foo() } else { bar() })"
		},
		{
			feat = "clean if else",
			expr = "if cond then foo() else bar()",
			expect = "(if cond then foo() else bar())"
		},
		{
			feat = "else if",
			expr = "if one then foo() else if two then bar()",
			expect = "(if one then foo() else (if two then bar()))"
		},
		{
			feat = "complex else if",
			expr = "if a == b then foo() + 1 else if a == c then bar() + 1",
			expect = "(if (== a b) then (+ foo() 1) else (if (== a c) then (+ bar() 1)))"
		},
		{
			feat = "infer member",
			expr = ".member",
			expect = ".member"
		},
		{
			feat = "nested infer member",
			expr = ".member.nested()",
			expect = ".member.nested()"
		},
		{
			feat = "break",
			expr = "break",
			expect = "(break )"
		},
		{
			feat = "labeled break",
			expr = "break :label",
			expect = "(break :label)"
		},
		{
			feat = "value break",
			expr = "break 1 + 1",
			expect = "(break (+ 1 1))"
		},
		{
			feat = "labeled value break",
			expr = "break :label 1 + 1",
			expect = "(break :label (+ 1 1))"
		},
		{
			feat = "loop",
			expr = "loop { foo() }",
			expect = "(loop { foo() })"
		},
		{
			feat = "clean loop",
			expr = "loop foo()",
			expect = "(loop foo())"
		},
		{
			feat = "while loop",
			expr = "while cond { foo() }",
			expect = "(while cond do { foo() })"
		},
		{
			feat = "clean while loop",
			expr = "while cond do foo()",
			expect = "(while cond do foo())"
		},
		{
			feat = "complex while loop",
			expr = "while a != b do foo()",
			expect = "(while (!= a b) do foo())"
		},
		{
			feat = "early return",
			expr = "return",
			expect = "(return )"
		},
		{
			feat = "early return with value",
			expr = "return a + b",
			expect = "(return (+ a b))"
		},
		{
			feat = "throw",
			expr = "throw SomeError.Case",
			expect = "(throw SomeError.Case)"
		},
		{
			feat = "assignment",
			expr = "variable = 1 + 2",
			expect = "(= variable (+ 1 2))"
		},
		{
			feat = "match",
			expr = [[
value match {
    1 -> "one"
    2 -> "two"
}]],
			expect = "(match value { 1 -> \"one\"; 2 -> \"two\" })"
		},
		{
			feat = "catch",
			expr = [[
foo() catch {
    io: IoError -> print("io")
    other: OtherError -> print("other")
}]],
			expect = 
	"(catch foo() { io:IoError -> print(\"io\"); other:OtherError -> print(\"other\") })"
		},
		{
			feat = "match patterns",
			expr = [[
value match {
    (1, 2) -> {}
    (let a, b) -> {}
    (let mut a, b) -> {}
    (let &a, b) -> {}
    (let mut &a, b) -> {}
    (let a, .EnumCase(let value)) -> {}
    .EnumCase(.OtherCase(let value)) -> {}
    .EnumCase(_) -> {}
    .EnumCase -> {}
    .EnumCase(let value) where value.is_foo() -> {}
    (_, 1) -> {}
    (_, _) -> {}
    _ where a == b -> {}
    _ -> {}
}]],
			expect = "???"
		},
		{
			feat = "match or",
			expr = [[
value match {
    .EnumCase or .OtherCase -> {}
}]],
			expect = "???"
		},
		{
			feat = "match subtype",
			expr = [[
value match {
    let object: ObjectSubtype -> {}
}]],
			expect = "???"
		},
		{
			feat = "if pattern",
			expr = "if .Some(let v) = optional { v } else { 0 }",
			expect = "(if (pat .Some(let v) = optional) then { v } else { 0 })"
		},
		{
			feat = "clean if pattern",
			expr = "if .Some(let v) = optional where v == 2 then v else 0",
			expect = "(if (pat .Some(let v) = optional where (== v 2)) then v else 0)"
		},
		{
			feat = "guard",
			expr = "guard .Some(let v) = optional where v == 2 else return",
			expect = "(guard (pat .Some(let v) = optional where (== v 2)) else (return ))"
		},
		{
			feat = "closure",
			expr = "|| x + y",
			expect = "(|| (+ x y))"
		},
		{
			feat = "closure with arguments",
			expr = "|x| x + y",
			expect = "(|x| (+ x y))"
		},
		{
			feat = "closure with multiple arguments",
			expr = "|x, y| x + y",
			expect = "(|x, y| (+ x y))"
		},
		{
			feat = "closure with explicit types",
			expr = "|x: Int| x + y",
			expect = "(|x:Int| (+ x y))"
		},
		{
			feat = "closure with binding qualification",
			expr = "|mut x, &y, mut &z| x + y",
			expect = "(|mut x, &y, mut &z| (+ x y))"
		},
		{
			feat = "binding",
			expr = "let mut &x: Int = 1 + 2",
			expect = "(let mut &x:Int (+ 1 2))"
		},
		{
			feat = "multiple assignment",
			expr = "(self.x, self.y) = (1, 2)",
			expect = "(= (self.x, self.y) (1, 2))"
		}
	}
	
	local passed = 0
	local failed = 0
	
	local function success()
		passed += 1
		
		--color(26)
		print("\fbPASSED\n")
	end
	
	local function failure(err)
		failed += 1
		
		print("\f8FAILED: \f7" .. (err.reason or err or pod(err)) .. "\n")
	end
	
	for test in all(expr_tests) do
		print("test: " .. test.feat)
		print("expr: " .. test.expr)
		
		if test.expect then
			print("exp: " .. test.expect)
		end
		
		local expr
		local suc, err = pcall(function()
			expr = parse_expr(tokenize(test.expr))
		end)
		if not suc then
			failure(err)
		else
			local str = tostring(expr)
			print("got: " .. str)
			
			if test.expect and test.expect ~= str then
				failure("mismatched result")
			else
				success()
			end
		end
	end
	
	if failed == 0 then
		print("\fbPASSED: " .. tostring(passed) .. " FAILED: " .. tostring(failed))
	else
		print("\f8PASSED: " .. tostring(passed) .. " FAILED: " .. tostring(failed))
	end
end

if not __STRC_LIB_MODE then
	main()
end

