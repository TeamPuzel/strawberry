{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "strawberry",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_token"
      }
    },
    "_token": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        },
        {
          "type": "SYMBOL",
          "name": "intrinsic"
        },
        {
          "type": "SYMBOL",
          "name": "keyword"
        },
        {
          "type": "SYMBOL",
          "name": "type_identifier"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        }
      ]
    },
    "comment": {
      "type": "PATTERN",
      "value": "\\/\\/[^\\n]*"
    },
    "string": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\"[^\"]*\""
        },
        {
          "type": "PATTERN",
          "value": "\\\\\\\\\\s.*"
        }
      ]
    },
    "number": {
      "type": "PATTERN",
      "value": "[0-9][0-9_]*(\\.[0-9_]+)?"
    },
    "intrinsic": {
      "type": "PATTERN",
      "value": "#[a-zA-Z0-9_]+"
    },
    "keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "guard"
        },
        {
          "type": "STRING",
          "value": "get"
        },
        {
          "type": "STRING",
          "value": "set"
        },
        {
