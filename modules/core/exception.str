module core

pub fun panic(because reason: String) -> Never {
    #panic(reason)
}

pub fun panic<with: Exception>(with exception: Exception) -> Never {
    panic(because: "uncaught exception: " + Exception::path)
}

/// A convenience panic function which can be used to abort unimplemented code during development.
pub fun todo() -> Never {
    panic(because: "todo")
}
